{%- comment -%}
  breadcrumbs.liquid — reusable, accessible breadcrumb trail with
  schema.org BreadcrumbList microdata (SEO). Auto-builds from the
  current template context. Param: class (optional extra css class).
{%- endcomment -%}
<nav class="mg-breadcrumbs {{ class }}" aria-label="{{ 'general.breadcrumbs.aria' | t | default: 'Breadcrumb' }}">
  <ol class="mg-breadcrumbs__list" itemscope itemtype="https://schema.org/BreadcrumbList">
    <li class="mg-breadcrumbs__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a class="mg-breadcrumbs__link" href="{{ routes.root_url }}" itemprop="item">
        <span itemprop="name">{{ 'general.breadcrumbs.home' | t | default: 'Home' }}</span>
      </a>
      <meta itemprop="position" content="1">
    </li>

    {%- case request.page_type -%}
      {%- when 'collection' -%}
        {%- if collection.handle -%}
          <li class="mg-breadcrumbs__item mg-breadcrumbs__item--current" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" aria-current="page">
            <span itemprop="name">{{ collection.title | escape }}</span>
            <meta itemprop="position" content="2">
          </li>
        {%- endif -%}

      {%- when 'product' -%}
        {%- if collection.url -%}
          <li class="mg-breadcrumbs__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a class="mg-breadcrumbs__link" href="{{ collection.url }}" itemprop="item"><span itemprop="name">{{ collection.title | escape }}</span></a>
            <meta itemprop="position" content="2">
          </li>
        {%- endif -%}
        <li class="mg-breadcrumbs__item mg-breadcrumbs__item--current" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" aria-current="page">
          <span itemprop="name">{{ product.title | escape }}</span>
          <meta itemprop="position" content="{% if collection.url %}3{% else %}2{% endif %}">
        </li>

      {%- when 'article' -%}
        {%- if blog.url -%}
          <li class="mg-breadcrumbs__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a class="mg-breadcrumbs__link" href="{{ blog.url }}" itemprop="item"><span itemprop="name">{{ blog.title | escape }}</span></a>
            <meta itemprop="position" content="2">
          </li>
        {%- endif -%}
        <li class="mg-breadcrumbs__item mg-breadcrumbs__item--current" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" aria-current="page">
          <span itemprop="name">{{ article.title | escape }}</span>
          <meta itemprop="position" content="3">
        </li>

      {%- when 'blog' -%}
        <li class="mg-breadcrumbs__item mg-breadcrumbs__item--current" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" aria-current="page">
          <span itemprop="name">{{ blog.title | escape }}</span>
          <meta itemprop="position" content="2">
        </li>

      {%- when 'page' -%}
        <li class="mg-breadcrumbs__item mg-breadcrumbs__item--current" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" aria-current="page">
          <span itemprop="name">{{ page.title | escape }}</span>
          <meta itemprop="position" content="2">
        </li>

      {%- when 'search' -%}
        <li class="mg-breadcrumbs__item mg-breadcrumbs__item--current" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" aria-current="page">
          <span itemprop="name">{{ 'general.breadcrumbs.search' | t | default: 'Search' }}</span>
          <meta itemprop="position" content="2">
        </li>
    {%- endcase -%}
  </ol>
</nav>
