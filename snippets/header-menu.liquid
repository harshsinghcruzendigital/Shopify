{%- comment -%}
  header-menu.liquid — desktop navigation list with up to 3 levels of
  dropdowns. Param: menu (a linklist). Mega menu enhancement lands in
  Component 3; this is the accessible baseline (hover + focus-within).
{%- endcomment -%}
{%- if menu != blank -%}
  <ul class="mg-header__menu">
    {%- for link in menu.links -%}
      {%- assign has_children = false -%}
      {%- if link.links.size > 0 -%}{%- assign has_children = true -%}{%- endif -%}
      <li class="mg-header__item {% if has_children %}has-dropdown{% endif %}">
        <a
          href="{{ link.url }}"
          class="mg-header__link"
          {% if link.current %}aria-current="page"{% endif %}
          {% if has_children %}aria-haspopup="true" aria-expanded="false"{% endif %}
        >
          {{ link.title | escape }}
          {%- if has_children -%}{%- render 'icon', name: 'chevron-down', size: 14 -%}{%- endif -%}
        </a>

        {%- if has_children -%}
          <div class="mg-header__dropdown">
            <ul>
              {%- for child in link.links -%}
                <li class="{% if child.links.size > 0 %}has-subdropdown{% endif %}">
                  <a href="{{ child.url }}" {% if child.current %}aria-current="page"{% endif %}>{{ child.title | escape }}</a>
                  {%- if child.links.size > 0 -%}
                    <ul class="mg-header__subdropdown">
                      {%- for grandchild in child.links -%}
                        <li><a href="{{ grandchild.url }}" {% if grandchild.current %}aria-current="page"{% endif %}>{{ grandchild.title | escape }}</a></li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </li>
    {%- endfor -%}
  </ul>
{%- endif -%}
