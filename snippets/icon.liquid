{%- comment -%}
  icon.liquid — central line-icon renderer.
  Usage: {% render 'icon', name: 'chevron-right', size: 16, class: 'mg-foo__icon' %}
  All icons: 24x24 grid, 1.5px stroke, currentColor, rounded caps.
  Add new icons to the case statement below — single source of truth.
{%- endcomment -%}
{%- liquid
  assign icon_size = size | default: 24
  assign icon_class = class | default: ''
-%}
<svg
  class="mg-icon mg-icon--{{ name }} {{ icon_class }}"
  width="{{ icon_size }}"
  height="{{ icon_size }}"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
>
  {%- case name -%}
    {%- when 'chevron-left' -%}
      <polyline points="15 18 9 12 15 6"></polyline>
    {%- when 'chevron-right' -%}
      <polyline points="9 18 15 12 9 6"></polyline>
    {%- when 'chevron-down' -%}
      <polyline points="6 9 12 15 18 9"></polyline>
    {%- when 'chevron-up' -%}
      <polyline points="18 15 12 9 6 15"></polyline>
    {%- when 'close' -%}
      <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
    {%- when 'menu' -%}
      <line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line>
    {%- when 'search' -%}
      <circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    {%- when 'user' -%}
      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle>
    {%- when 'bag' -%}
      <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path>
    {%- when 'heart' -%}
      <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 0 0-7.8 7.8l1 1.1L12 21l7.8-7.5 1-1.1a5.5 5.5 0 0 0 0-7.8z"></path>
    {%- when 'truck' -%}
      <rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle>
    {%- when 'gift' -%}
      <polyline points="20 12 20 22 4 22 4 12"></polyline><rect x="2" y="7" width="20" height="5"></rect><line x1="12" y1="22" x2="12" y2="7"></line><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
    {%- when 'globe' -%}
      <circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
    {%- when 'star' -%}
      <polygon points="12 2 15.1 8.6 22 9.3 17 14.1 18.2 21 12 17.8 5.8 21 7 14.1 2 9.3 8.9 8.6 12 2"></polygon>
    {%- when 'tag' -%}
      <path d="M20.6 13.4 13.4 20.6a2 2 0 0 1-2.8 0L3 13V3h10l7.6 7.6a2 2 0 0 1 0 2.8z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line>
    {%- when 'arrow-up' -%}
      <line x1="12" y1="19" x2="12" y2="5"></line><polyline points="5 12 12 5 19 12"></polyline>
    {%- when 'plus' -%}
      <line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line>
    {%- when 'minus' -%}
      <line x1="5" y1="12" x2="19" y2="12"></line>
    {%- when 'phone' -%}
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"></path>
    {%- when 'mail' -%}
      <rect x="2" y="4" width="20" height="16" rx="2"></rect><polyline points="22 6 12 13 2 6"></polyline>
    {%- when 'instagram' -%}
      <rect x="2" y="2" width="20" height="20" rx="5"></rect><circle cx="12" cy="12" r="4"></circle><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
    {%- when 'facebook' -%}
      <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
    {%- when 'pinterest' -%}
      <path d="M9 19c-.5 1.5-1 3-1 3"></path><path d="M9.5 14.5c.5 1 1.4 1.5 2.5 1.5 2.8 0 5-2.5 5-5.5S14.8 5 12 5a5.5 5.5 0 0 0-5.5 5.5c0 1.5.7 2.6 1.7 3.2"></path><circle cx="12" cy="11" r="7.5"></circle>
    {%- when 'youtube' -%}
      <path d="M22 12s0-3.2-.4-4.7a2.5 2.5 0 0 0-1.8-1.8C18.3 5 12 5 12 5s-6.3 0-7.8.5A2.5 2.5 0 0 0 2.4 7.3C2 8.8 2 12 2 12s0 3.2.4 4.7a2.5 2.5 0 0 0 1.8 1.8C5.7 19 12 19 12 19s6.3 0 7.8-.5a2.5 2.5 0 0 0 1.8-1.8C22 15.2 22 12 22 12z"></path><polygon points="10 9 15 12 10 15 10 9"></polygon>
    {%- when 'tiktok' -%}
      <path d="M16 3c.5 2.5 2 4 4.5 4.3V10c-1.7 0-3.2-.5-4.5-1.4V15a5.5 5.5 0 1 1-5.5-5.5c.3 0 .7 0 1 .1v2.8a2.7 2.7 0 1 0 1.9 2.6V3z"></path>
    {%- when 'x' -%}
      <path d="M4 4l7 9-7 7h2l6-6 5 6h4l-7.5-9.5L20 4h-2l-5.5 5.5L8 4z"></path>
    {%- else -%}
      <circle cx="12" cy="12" r="9"></circle>
  {%- endcase -%}
</svg>
