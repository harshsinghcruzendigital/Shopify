{%- comment -%}
  collection-card.liquid — reusable luxury collection card (DS §16).
  Params:
    collection      (required) collection object
    image_override  (optional) image to use instead of collection.image
    heading         (optional) title override (defaults to collection.title)
    ratio           (optional) aspect ratio, default '3/4'
    style           (optional) 'overlay' (text over image) | 'below'
    cta_text        (optional) shows a button/text link
    cta_style       (optional) button style, default 'outline'
    sizes           (optional) responsive sizes attr
    loading         (optional) 'lazy' (default) | 'eager'
{%- endcomment -%}
{%- liquid
  assign ratio = ratio | default: '3/4'
  assign style = style | default: 'overlay'
  assign img = image_override | default: collection.image
  if img == blank
    assign img = collection.featured_image
  endif
  assign title = heading | default: collection.title
  assign card_sizes = sizes | default: '(min-width: 990px) 33vw, 100vw'
  assign card_loading = loading | default: 'lazy'
-%}

<a class="mg-coll-card mg-coll-card--{{ style }}" href="{{ collection.url }}">
  <div class="mg-coll-card__media">
    {%- if img != blank -%}
      {%- render 'responsive-image', image: img, sizes: card_sizes, class: 'mg-coll-card__img', loading: card_loading, aspect_ratio: ratio -%}
    {%- else -%}
      <div class="mg-image-placeholder" style="aspect-ratio: {{ ratio }};">{{ 'collection-1' | placeholder_svg_tag: 'mg-image-placeholder__svg' }}</div>
    {%- endif -%}
    {%- if style == 'overlay' -%}<span class="mg-coll-card__scrim" aria-hidden="true"></span>{%- endif -%}

    {%- if style == 'overlay' -%}
      <div class="mg-coll-card__content">
        <h3 class="mg-coll-card__title">{{ title | escape }}</h3>
        {%- if cta_text != blank -%}<span class="mg-coll-card__cta">{{ cta_text | escape }}</span>{%- endif -%}
      </div>
    {%- endif -%}
  </div>

  {%- if style == 'below' -%}
    <div class="mg-coll-card__content mg-coll-card__content--below">
      <h3 class="mg-coll-card__title">{{ title | escape }}</h3>
      {%- if cta_text != blank -%}<span class="mg-coll-card__cta mg-btn mg-btn--text">{{ cta_text | escape }}</span>{%- endif -%}
    </div>
  {%- endif -%}
</a>
