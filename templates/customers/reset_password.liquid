<div class="mg-account">
  <div class="mg-account__inner">
    <h1 class="mg-account__title">{{ 'customer.reset.title' | t | default: 'Reset your password' }}</h1>
    {%- form 'reset_customer_password', class: 'mg-account__form' -%}
      {%- if form.errors -%}<div class="mg-account__errors">{{ form.errors | default_errors }}</div>{%- endif -%}
      <label class="mg-field"><span>{{ 'customer.reset.new_password' | t | default: 'New password' }}</span><input type="password" name="customer[password]" autocomplete="new-password" required></label>
      <label class="mg-field"><span>{{ 'customer.reset.confirm' | t | default: 'Confirm password' }}</span><input type="password" name="customer[password_confirmation]" autocomplete="new-password" required></label>
      <button type="submit" class="mg-btn mg-btn--primary">{{ 'customer.reset.submit' | t | default: 'Reset password' }}</button>
    {%- endform -%}
  </div>
</div>
