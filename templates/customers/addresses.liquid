<div class="mg-account">
  <div class="mg-account__inner">
    <h1 class="mg-account__title">{{ 'customer.addresses.title' | t | default: 'Addresses' }}</h1>

    {%- form 'customer_address', customer.new_address, class: 'mg-account__form' -%}
      <h2 style="font-family:var(--mg-font-display);font-size:var(--mg-fs-card-heading);">{{ 'customer.addresses.add' | t | default: 'Add a new address' }}</h2>
      <div class="mg-contact__row">
        <label class="mg-field"><span>{{ 'customer.first_name' | t }}</span><input type="text" name="address[first_name]"></label>
        <label class="mg-field"><span>{{ 'customer.last_name' | t }}</span><input type="text" name="address[last_name]"></label>
      </div>
      <label class="mg-field"><span>{{ 'customer.addresses.address1' | t | default: 'Address' }}</span><input type="text" name="address[address1]"></label>
      <div class="mg-contact__row">
        <label class="mg-field"><span>{{ 'customer.addresses.city' | t | default: 'City' }}</span><input type="text" name="address[city]"></label>
        <label class="mg-field"><span>{{ 'customer.addresses.zip' | t | default: 'ZIP / Postal' }}</span><input type="text" name="address[zip]"></label>
      </div>
      <label class="mg-field"><span>{{ 'customer.addresses.country' | t | default: 'Country' }}</span><input type="text" name="address[country]"></label>
      <button type="submit" class="mg-btn mg-btn--primary">{{ 'customer.addresses.save' | t | default: 'Save address' }}</button>
    {%- endform -%}

    {%- if customer.addresses.size > 0 -%}
      <div style="margin-top:2.5rem;">
        <h2 style="font-family:var(--mg-font-display);font-size:var(--mg-fs-card-heading);margin-bottom:1rem;">{{ 'customer.addresses.saved' | t | default: 'Saved addresses' }}</h2>
        {%- for address in customer.addresses -%}
          <div style="padding:1rem 0;border-bottom:1px solid var(--mg-border-divider);">
            {%- if address == customer.default_address -%}<p class="mg-eyebrow">{{ 'customer.addresses.default' | t | default: 'Default' }}</p>{%- endif -%}
            {{ address | format_address }}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
    <p class="mg-account__links"><a href="{{ routes.account_url }}">&larr; {{ 'customer.account.return' | t }}</a></p>
  </div>
</div>
