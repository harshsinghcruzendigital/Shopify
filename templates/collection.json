{
  "sections": {
    "collection-hero": {
      "type": "collection-banner",
      "settings": {
        "layout": "banner",
        "alignment": "center",
        "height": "medium",
        "use_collection_image": true,
        "show_breadcrumb": true,
        "show_description": true,
        "overlay_opacity": 35
      }
    },
    "collection-story": {
      "type": "collection-story",
      "settings": {
        "layout": "image-right",
        "eyebrow": "Our Story",
        "heading": "Crafted with intention",
        "image_ratio": "4/5"
      }
    },
    "product-grid": {
      "type": "main-collection",
      "settings": {
        "columns_desktop": 4,
        "columns_tablet": 3,
        "columns_mobile": 2,
        "pagination_type": "load_more",
        "show_sort": true,
        "show_grid_toggle": true,
        "show_filters": true
      }
    },
    "editorial-banner": {
      "type": "editorial-banner",
      "settings": {
        "full_width": true,
        "height": "medium",
        "content_x": "left",
        "content_y": "bottom",
        "heading": "The Heritage Collection",
        "overlay_opacity": 30
      }
    },
    "featured-collection": {
      "type": "featured-collection",
      "settings": {
        "eyebrow": "Curated",
        "heading": "Editor's Picks",
        "layout": "carousel",
        "columns": 4,
        "product_limit": 8
      }
    },
    "collection-seo": {
      "type": "collection-seo",
      "settings": {
        "use_collection_description": true,
        "collapsible": true,
        "narrow": true
      }
    },
    "related-collections": {
      "type": "related-collections",
      "settings": {
        "eyebrow": "Explore",
        "heading": "You may also like",
        "layout": "grid",
        "columns": 3,
        "card_style": "overlay"
      },
      "blocks": {
        "c1": { "type": "collection" },
        "c2": { "type": "collection" },
        "c3": { "type": "collection" }
      },
      "block_order": ["c1", "c2", "c3"]
    },
    "recently-viewed": {
      "type": "recently-viewed",
      "settings": {
        "eyebrow": "Continue browsing",
        "heading": "Recently viewed",
        "product_limit": 8
      }
    }
  },
  "order": ["collection-hero", "collection-story", "product-grid", "editorial-banner", "featured-collection", "collection-seo", "related-collections", "recently-viewed"]
}
