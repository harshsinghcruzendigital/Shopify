{%- comment -%}
  ============================================================
  Madrishi Global — Footer
  Luxury multi-column footer built from blocks (brand, menu, text,
  newsletter) + a bottom bar (payment icons, localization, social,
  copyright, secondary menu). Lives in the footer section group.
  ============================================================
{%- endcomment -%}

<footer
  class="mg-footer {{ section.settings.custom_class }}"
  style="
    --mg-footer-bg: {{ section.settings.background }};
    --mg-footer-text: {{ section.settings.text_color }};
    --mg-footer-muted: {{ section.settings.muted_color }};
    --mg-footer-pad-top: {{ section.settings.padding_top }}px;
  "
  data-mg-animate-section
>
  {%- if section.blocks.size > 0 -%}
    <div class="mg-footer__main mg-container">
      <div class="mg-footer__columns">
        {%- for block in section.blocks -%}
          <div class="mg-footer__col mg-footer__col--{{ block.type }}" {{ block.shopify_attributes }} data-mg-animate>
            {%- case block.type -%}
              {%- when 'brand' -%}
                {%- if block.settings.logo != blank -%}
                  <img class="mg-footer__logo" src="{{ block.settings.logo | image_url: width: 400 }}" width="{{ block.settings.logo.width }}" height="{{ block.settings.logo.height }}" alt="{{ shop.name | escape }}" style="width: {{ block.settings.logo_width }}px;" loading="lazy">
                {%- elsif block.settings.heading != blank -%}
                  <p class="mg-footer__brand-name">{{ block.settings.heading | escape }}</p>
                {%- endif -%}
                {%- if block.settings.text != blank -%}<div class="mg-footer__brand-text rte">{{ block.settings.text }}</div>{%- endif -%}
                {%- if block.settings.show_social -%}{%- render 'social-icons', class: 'mg-footer__social' -%}{%- endif -%}

              {%- when 'menu' -%}
                {%- if block.settings.heading != blank -%}<p class="mg-footer__heading">{{ block.settings.heading | escape }}</p>{%- endif -%}
                {%- if block.settings.menu != blank -%}
                  <ul class="mg-footer__list">
                    {%- for link in block.settings.menu.links -%}
                      <li><a class="mg-footer__link" href="{{ link.url }}">{{ link.title | escape }}</a></li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}

              {%- when 'text' -%}
                {%- if block.settings.heading != blank -%}<p class="mg-footer__heading">{{ block.settings.heading | escape }}</p>{%- endif -%}
                {%- if block.settings.text != blank -%}<div class="mg-footer__text rte">{{ block.settings.text }}</div>{%- endif -%}

              {%- when 'newsletter' -%}
                {%- if block.settings.heading != blank -%}<p class="mg-footer__heading">{{ block.settings.heading | escape }}</p>{%- endif -%}
                {%- if block.settings.text != blank -%}<div class="mg-footer__text rte">{{ block.settings.text }}</div>{%- endif -%}
                {%- form 'customer', class: 'mg-footer__newsletter' -%}
                  <input type="hidden" name="contact[tags]" value="newsletter">
                  {%- if form.posted_successfully? -%}
                    <p class="mg-footer__newsletter-success">{{ 'newsletter.success' | t | default: 'Thank you for subscribing.' }}</p>
                  {%- else -%}
                    <div class="mg-footer__newsletter-field">
                      <label class="visually-hidden" for="mg-footer-email-{{ block.id }}">{{ 'newsletter.email' | t | default: 'Email' }}</label>
                      <input id="mg-footer-email-{{ block.id }}" type="email" name="contact[email]" placeholder="{{ 'newsletter.placeholder' | t | default: 'Enter your email' }}" required autocomplete="email">
                      <button type="submit" class="mg-footer__newsletter-btn" aria-label="{{ 'newsletter.subscribe' | t | default: 'Subscribe' }}">{%- render 'icon', name: 'arrow-up', size: 18 -%}</button>
                    </div>
                    {%- if form.errors -%}<p class="mg-footer__newsletter-error">{{ form.errors.translated_fields.email }} {{ form.errors.messages.email }}</p>{%- endif -%}
                  {%- endif -%}
                {%- endform -%}
            {%- endcase -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  <div class="mg-footer__bottom">
    <div class="mg-footer__bottom-inner mg-container">
      <p class="mg-footer__copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.copyright_text | default: 'All rights reserved.' }}</p>

      {%- if section.settings.secondary_menu != blank -%}
        <ul class="mg-footer__secondary">
          {%- for link in section.settings.secondary_menu.links -%}
            <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      <div class="mg-footer__bottom-right">
        {%- if section.settings.show_localization -%}
          <div class="mg-footer__localization">
            {%- render 'localization-form', type: 'country', id: 'footer' -%}
            {%- render 'localization-form', type: 'language', id: 'footer' -%}
          </div>
        {%- endif -%}
        {%- if section.settings.show_payment_icons and shop.enabled_payment_types.size > 0 -%}
          <ul class="mg-footer__payments" role="list" aria-label="{{ 'footer.payment_methods' | t | default: 'Payment methods' }}">
            {%- for type in shop.enabled_payment_types -%}
              <li>{{ type | payment_type_svg_tag: class: 'mg-footer__payment-icon' }}</li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% stylesheet %}
.mg-footer { background: var(--mg-footer-bg, var(--mg-navy)); color: var(--mg-footer-text, var(--mg-ivory)); }
.mg-footer__main { padding-block: var(--mg-footer-pad-top, var(--mg-space-12)) var(--mg-space-10); }
.mg-footer__columns { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: var(--mg-space-9); }
.mg-footer__col--brand, .mg-footer__col--newsletter { grid-column: span 1; }

.mg-footer__logo { margin-bottom: var(--mg-space-4); filter: brightness(0) invert(1); }
.mg-footer__brand-name { font-family: var(--mg-font-display); font-size: var(--mg-fs-collection-title); margin-bottom: var(--mg-space-4); color: var(--mg-footer-text, var(--mg-ivory)); }
.mg-footer__brand-text { color: var(--mg-footer-muted, #B6BCCB); font-size: var(--mg-fs-body-sm); line-height: var(--mg-lh-body); max-width: 36ch; }
.mg-footer__social { margin-top: var(--mg-space-5); color: var(--mg-footer-text, var(--mg-ivory)); }

.mg-footer__heading { font-family: var(--mg-font-eyebrow); font-size: var(--mg-fs-caption); font-weight: 600; letter-spacing: var(--mg-track-wider); text-transform: uppercase; color: var(--mg-footer-text, var(--mg-ivory)); margin-bottom: var(--mg-space-5); }
.mg-footer__list { display: flex; flex-direction: column; gap: var(--mg-space-3); }
.mg-footer__link, .mg-footer__text { color: var(--mg-footer-muted, #B6BCCB); font-size: var(--mg-fs-body-sm); }
.mg-footer__link:hover { color: var(--mg-gold); }

.mg-footer__newsletter-field { display: flex; align-items: center; border-bottom: var(--mg-border-hairline) solid rgba(255,255,255,0.3); }
.mg-footer__newsletter-field input { flex: 1; background: transparent; border: 0; color: var(--mg-footer-text, var(--mg-ivory)); padding: var(--mg-space-3) 0; }
.mg-footer__newsletter-field input::placeholder { color: var(--mg-footer-muted, #B6BCCB); }
.mg-footer__newsletter-field input:focus { outline: none; }
.mg-footer__newsletter-btn { color: var(--mg-footer-text, var(--mg-ivory)); padding: var(--mg-space-2); }
.mg-footer__newsletter-btn:hover { color: var(--mg-gold); }
.mg-footer__newsletter-success { color: var(--mg-gold); font-size: var(--mg-fs-body-sm); }
.mg-footer__newsletter-error { color: #E2A6A0; font-size: var(--mg-fs-caption); margin-top: var(--mg-space-2); }

.mg-footer__bottom { border-top: var(--mg-border-hairline) solid rgba(255,255,255,0.12); }
.mg-footer__bottom-inner { display: flex; align-items: center; justify-content: space-between; gap: var(--mg-space-4); flex-wrap: wrap; padding-block: var(--mg-space-5); }
.mg-footer__copyright { font-size: var(--mg-fs-caption); color: var(--mg-footer-muted, #B6BCCB); }
.mg-footer__secondary { display: flex; gap: var(--mg-space-4); }
.mg-footer__secondary a { font-size: var(--mg-fs-caption); color: var(--mg-footer-muted, #B6BCCB); }
.mg-footer__secondary a:hover { color: var(--mg-gold); }
.mg-footer__bottom-right { display: flex; align-items: center; gap: var(--mg-space-5); }
.mg-footer__payments { display: flex; align-items: center; gap: var(--mg-space-2); }
.mg-footer__payment-icon { width: 38px; height: 24px; }
.mg-footer__localization { display: flex; gap: var(--mg-space-3); color: var(--mg-footer-text, var(--mg-ivory)); }

[data-mg-animate-section] [data-mg-animate] { opacity: 0; transform: translateY(16px); transition: opacity var(--mg-dur-slow) var(--mg-ease), transform var(--mg-dur-slow) var(--mg-ease); }
[data-mg-animate-section].is-revealed [data-mg-animate] { opacity: 1; transform: none; }

@media (max-width: 767px) {
  .mg-footer__bottom-inner { flex-direction: column; align-items: flex-start; }
}
@media (prefers-reduced-motion: reduce) { [data-mg-animate-section] [data-mg-animate] { opacity: 1 !important; transform: none !important; } }
{% endstyle %}

{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "class": "mg-footer-section",
  "settings": [
    { "type": "header", "content": "Style" },
    { "type": "color", "id": "background", "label": "Background", "default": "#1B2A4A" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#F7F4EC" },
    { "type": "color", "id": "muted_color", "label": "Muted text", "default": "#B6BCCB" },
    { "type": "range", "id": "padding_top", "min": 40, "max": 160, "step": 8, "unit": "px", "label": "Top padding", "default": 96 },

    { "type": "header", "content": "Bottom bar" },
    { "type": "text", "id": "copyright_text", "label": "Copyright suffix", "default": "All rights reserved." },
    { "type": "link_list", "id": "secondary_menu", "label": "Secondary menu", "info": "e.g. Privacy, Terms" },
    { "type": "checkbox", "id": "show_localization", "label": "Show country/language selector", "default": true },
    { "type": "checkbox", "id": "show_payment_icons", "label": "Show payment icons", "default": true },

    { "type": "header", "content": "Advanced" },
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "limit": 1,
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Logo" },
        { "type": "range", "id": "logo_width", "min": 80, "max": 240, "step": 10, "unit": "px", "label": "Logo width", "default": 150 },
        { "type": "text", "id": "heading", "label": "Brand name", "info": "Used if no logo" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Timeless luxury, globally crafted.</p>" },
        { "type": "checkbox", "id": "show_social", "label": "Show social icons", "default": true }
      ]
    },
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Explore" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Customer Care" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>concierge@madrishi.com</p>" }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Join the House" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Receive first access to new collections and private events.</p>" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "brand" },
        { "type": "menu" },
        { "type": "text" },
        { "type": "newsletter" }
      ]
    }
  ]
}
{% endschema %}
