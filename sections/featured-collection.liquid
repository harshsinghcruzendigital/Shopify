{%- comment -%}
  ============================================================
  Madrishi Global — Featured Collection ("Editor's Picks")
  Curated product row from a chosen collection, as a responsive grid
  OR a scroll-snap carousel (reusable <mg-carousel>). Reuses
  product-card. Works on collection page and homepage.
  ============================================================
{%- endcomment -%}

{%- liquid
  assign featured = section.settings.collection
  assign limit = section.settings.product_limit
  assign is_carousel = false
  if section.settings.layout == 'carousel'
    assign is_carousel = true
  endif
  assign cols = section.settings.columns
  assign card_w = 100 | divided_by: cols
-%}

<section
  class="mg-featured {{ section.settings.custom_class }}"
  id="{{ section.settings.anchor_id | default: section.id }}"
  style="
    --mg-featured-bg: {{ section.settings.background }};
    --mg-featured-text: {{ section.settings.text_color }};
    --mg-featured-pad-top: {{ section.settings.padding_top }}px;
    --mg-featured-pad-bottom: {{ section.settings.padding_bottom }}px;
    --mg-cols: {{ cols }};
    --mg-carousel-item-d: calc({{ card_w }}% - var(--mg-space-5));
  "
  {% if section.settings.animate %}data-mg-animate-section{% endif %}
>
  <div class="mg-featured__inner mg-container">
    <div class="mg-featured__header mg-section-header {% if section.settings.heading_alignment == 'center' %}mg-section-header--center{% endif %}">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="mg-section-header__eyebrow mg-eyebrow" data-mg-animate>{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="mg-section-header__title" data-mg-animate>{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subtext != blank -%}
          <div class="mg-section-header__text rte" data-mg-animate>{{ section.settings.subtext }}</div>
        {%- endif -%}
      </div>
      {%- if section.settings.show_view_all and featured != blank -%}
        <a class="mg-btn mg-btn--text mg-featured__view-all" href="{{ featured.url }}" data-mg-animate>
          {{ section.settings.view_all_text | default: 'View all' | escape }}
        </a>
      {%- endif -%}
    </div>

    {%- if featured != blank and featured.products_count > 0 -%}
      {%- if is_carousel -%}
        <mg-carousel class="mg-carousel mg-featured__carousel" data-mg-animate>
          <button class="mg-carousel__arrow mg-carousel__arrow--prev" type="button" data-mg-carousel-prev aria-label="{{ 'general.accessibility.previous' | t }}">{%- render 'icon', name: 'chevron-left' -%}</button>
          <ul class="mg-carousel__track" data-mg-carousel-track role="list">
            {%- for product in featured.products limit: limit -%}
              <li>{%- render 'product-card', product: product, image_ratio: section.settings.card_image_ratio, show_vendor: section.settings.show_vendor, show_rating: section.settings.show_rating, show_swatches: section.settings.show_swatches, show_quick_view: section.settings.show_quick_view, sizes: '(min-width: 990px) 25vw, 60vw' -%}</li>
            {%- endfor -%}
          </ul>
          <button class="mg-carousel__arrow mg-carousel__arrow--next" type="button" data-mg-carousel-next aria-label="{{ 'general.accessibility.next' | t }}">{%- render 'icon', name: 'chevron-right' -%}</button>
        </mg-carousel>
      {%- else -%}
        <ul class="mg-featured__grid" role="list" data-mg-animate>
          {%- for product in featured.products limit: limit -%}
            <li>{%- render 'product-card', product: product, image_ratio: section.settings.card_image_ratio, show_vendor: section.settings.show_vendor, show_rating: section.settings.show_rating, show_swatches: section.settings.show_swatches, show_quick_view: section.settings.show_quick_view, sizes: '(min-width: 990px) 25vw, 50vw' -%}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    {%- else -%}
      <ul class="mg-featured__grid" role="list">
        {%- for i in (1..cols) -%}
          <li><div class="mg-image-placeholder" style="aspect-ratio: {{ section.settings.card_image_ratio }};">{{ 'product-' | append: i | placeholder_svg_tag: 'mg-image-placeholder__svg' }}</div></li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.mg-featured { background: var(--mg-featured-bg, transparent); color: var(--mg-featured-text, var(--mg-text)); padding-block: var(--mg-featured-pad-top, var(--mg-section-spacing)) var(--mg-featured-pad-bottom, var(--mg-section-spacing)); }
.mg-featured__header { display: flex; align-items: flex-end; justify-content: space-between; gap: var(--mg-space-5); flex-wrap: wrap; }
.mg-featured__header.mg-section-header--center { justify-content: center; text-align: center; }
.mg-section-header__title { color: inherit; }
.mg-featured__view-all { flex: 0 0 auto; white-space: nowrap; }
.mg-featured__grid { display: grid; grid-template-columns: repeat(var(--mg-cols, 4), minmax(0, 1fr)); gap: var(--mg-space-6) var(--mg-space-6); list-style: none; margin: 0; padding: 0; }

[data-mg-animate-section] [data-mg-animate] { opacity: 0; transform: translateY(20px); transition: opacity var(--mg-dur-slow) var(--mg-ease), transform var(--mg-dur-slow) var(--mg-ease); }
[data-mg-animate-section].is-revealed [data-mg-animate] { opacity: 1; transform: none; }

@media (max-width: 989px) { .mg-featured__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
@media (max-width: 767px) { .mg-featured__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--mg-space-4); } }
@media (prefers-reduced-motion: reduce) { [data-mg-animate-section] [data-mg-animate] { opacity: 1 !important; transform: none !important; } }
{% endstyle %}

{% schema %}
{
  "name": "Featured collection",
  "tag": "section",
  "class": "mg-featured-section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Curated" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Editor's Picks" },
    { "type": "richtext", "id": "subtext", "label": "Subtext" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_limit", "min": 2, "max": 12, "step": 1, "label": "Products to show", "default": 8 },
    { "type": "select", "id": "heading_alignment", "label": "Heading alignment", "options": [ { "value": "left", "label": "Left (with view-all)" }, { "value": "center", "label": "Center" } ], "default": "left" },
    { "type": "checkbox", "id": "show_view_all", "label": "Show view-all link", "default": true },
    { "type": "text", "id": "view_all_text", "label": "View-all label", "default": "View all" },

    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "layout", "label": "Layout", "options": [ { "value": "grid", "label": "Grid" }, { "value": "carousel", "label": "Carousel" } ], "default": "carousel" },
    { "type": "range", "id": "columns", "min": 2, "max": 5, "step": 1, "label": "Columns / per view", "default": 4 },
    { "type": "select", "id": "card_image_ratio", "label": "Card image ratio", "options": [ { "value": "3/4", "label": "Portrait (3:4)" }, { "value": "4/5", "label": "Portrait (4:5)" }, { "value": "1/1", "label": "Square" } ], "default": "3/4" },

    { "type": "header", "content": "Product card" },
    { "type": "checkbox", "id": "show_vendor", "label": "Show vendor", "default": false },
    { "type": "checkbox", "id": "show_rating", "label": "Show rating", "default": true },
    { "type": "checkbox", "id": "show_swatches", "label": "Show swatches", "default": true },
    { "type": "checkbox", "id": "show_quick_view", "label": "Show quick view", "default": true },

    { "type": "header", "content": "Style" },
    { "type": "color", "id": "background", "label": "Background", "default": "#FBF8F2" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#1C1C1C" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding top", "default": 96 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding bottom", "default": 96 },

    { "type": "header", "content": "Advanced" },
    { "type": "checkbox", "id": "animate", "label": "Animate on scroll", "default": true },
    { "type": "text", "id": "anchor_id", "label": "Section anchor ID" },
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" }
  ],
  "presets": [ { "name": "Featured collection" } ]
}
{% endschema %}
