{%- comment -%}
  Madrishi Global — Homepage Section 14: Awards & Recognition
  Editorial timeline of awards (year + title + text + optional logo).
  No section JS.
{%- endcomment -%}
<section
  class="mg-awards {{ section.settings.custom_class }}"
  id="{{ section.settings.anchor_id | default: section.id }}"
  style="--mg-awards-bg: {{ section.settings.background }}; --mg-awards-text: {{ section.settings.text_color }}; --mg-awards-pad-top: {{ section.settings.padding_top }}px; --mg-awards-pad-bottom: {{ section.settings.padding_bottom }}px;"
  data-mg-animate-section
>
  <div class="mg-awards__inner mg-container mg-container--narrow">
    <div class="mg-section-header mg-section-header--center">
      {%- if section.settings.eyebrow != blank -%}<p class="mg-section-header__eyebrow mg-eyebrow" data-mg-animate>{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="mg-section-header__title" data-mg-animate>{{ section.settings.heading | escape }}</h2>{%- endif -%}
    </div>

    <ol class="mg-awards__timeline">
      {%- for block in section.blocks -%}
        <li class="mg-awards__item" {{ block.shopify_attributes }} data-mg-animate>
          {%- if block.settings.year != blank -%}<span class="mg-awards__year">{{ block.settings.year | escape }}</span>{%- endif -%}
          <div class="mg-awards__body">
            {%- if block.settings.title != blank -%}<h3 class="mg-awards__title">{{ block.settings.title | escape }}</h3>{%- endif -%}
            {%- if block.settings.text != blank -%}<p class="mg-awards__text">{{ block.settings.text | escape }}</p>{%- endif -%}
          </div>
        </li>
      {%- endfor -%}
    </ol>
  </div>
</section>

{% stylesheet %}
.mg-awards { background: var(--mg-awards-bg, var(--mg-bg-page)); color: var(--mg-awards-text, var(--mg-text)); padding-block: var(--mg-awards-pad-top, var(--mg-section-spacing)) var(--mg-awards-pad-bottom, var(--mg-section-spacing)); }
.mg-awards .mg-section-header__title { color: inherit; }
.mg-awards__timeline { border-top: var(--mg-border-hairline) solid var(--mg-border-divider); }
.mg-awards__item { display: grid; grid-template-columns: 120px 1fr; gap: var(--mg-space-6); padding: var(--mg-space-6) 0; border-bottom: var(--mg-border-hairline) solid var(--mg-border-divider); align-items: baseline; }
.mg-awards__year { font-family: var(--mg-font-display); font-size: var(--mg-fs-card-heading); color: var(--mg-gold); }
.mg-awards__title { font-family: var(--mg-font-display); font-size: var(--mg-fs-product-title); font-weight: 500; margin-bottom: var(--mg-space-1); color: inherit; }
.mg-awards__text { color: var(--mg-text-secondary); font-size: var(--mg-fs-body-sm); }
[data-mg-animate-section] [data-mg-animate] { opacity: 0; transform: translateY(16px); transition: opacity var(--mg-dur-slow) var(--mg-ease), transform var(--mg-dur-slow) var(--mg-ease); }
[data-mg-animate-section].is-revealed [data-mg-animate] { opacity: 1; transform: none; }
@media (max-width: 600px) { .mg-awards__item { grid-template-columns: 1fr; gap: var(--mg-space-2); } }
@media (prefers-reduced-motion: reduce) { [data-mg-animate-section] [data-mg-animate] { opacity: 1 !important; transform: none !important; } }
{% endstyle %}

{% schema %}
{
  "name": "Awards",
  "tag": "section",
  "class": "mg-awards-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Recognition" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Awards & Honours" },
    { "type": "color", "id": "background", "label": "Background", "default": "#FBF8F2" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#1C1C1C" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 200, "step": 8, "unit": "px", "label": "Padding top", "default": 120 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 200, "step": 8, "unit": "px", "label": "Padding bottom", "default": 120 },
    { "type": "text", "id": "anchor_id", "label": "Section anchor ID" },
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" }
  ],
  "blocks": [
    {
      "type": "award",
      "name": "Award",
      "settings": [
        { "type": "text", "id": "year", "label": "Year", "default": "2025" },
        { "type": "text", "id": "title", "label": "Title", "default": "Luxury House of the Year" },
        { "type": "text", "id": "text", "label": "Text", "default": "International Design Council" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [ { "name": "Awards", "blocks": [ { "type": "award" }, { "type": "award", "settings": { "year": "2024", "title": "Excellence in Craftsmanship" } }, { "type": "award", "settings": { "year": "2023", "title": "Sustainable Luxury Award" } } ] } ]
}
{% endschema %}
