{%- comment -%}
  ============================================================
  Madrishi Global — Announcement Bar
  Rotating, dismissible, accessible announcement bar.
  - Multiple announcement blocks (text + optional icon + optional link)
  - Optional per-block countdown timer
  - Auto-rotate with speed control + pause-on-hover
  - Manual prev/next + dots
  - Dismiss with localStorage memory (keyed by content hash)
  - Fully theme-editor configurable; nothing hardcoded
  Custom element: <mg-announcement-bar>
  ============================================================
{%- endcomment -%}

{%- liquid
  assign block_count = section.blocks.size
  assign show_nav = false
  if block_count > 1 and section.settings.autorotate
    assign show_nav = section.settings.show_arrows
  endif
-%}

{%- if block_count > 0 -%}
  <mg-announcement-bar
    class="mg-announcement {% if section.settings.show_on_desktop == false %}mg-hide-desktop{% endif %} {% if section.settings.show_on_mobile == false %}mg-hide-mobile{% endif %} {{ section.settings.custom_class }}"
    id="mg-announcement-{{ section.id }}"
    {% if section.settings.autorotate and block_count > 1 %}data-autorotate="true" data-speed="{{ section.settings.rotation_speed | times: 1000 }}"{% endif %}
    {% if section.settings.pause_on_hover %}data-pause-on-hover="true"{% endif %}
    {% if section.settings.animate %}data-animate="true"{% endif %}
    role="region"
    aria-label="{{ 'sections.announcement_bar.countdown_ended' | t | default: 'Announcements' }}"
    style="
      --mg-ann-bg: {{ section.settings.bg_color }};
      --mg-ann-text: {{ section.settings.text_color }};
      --mg-ann-fs: {{ section.settings.font_size }}px;
      --mg-ann-height: {{ section.settings.height }}px;
      --mg-ann-pad: {{ section.settings.padding_inline }}px;
    "
  >
    <div class="mg-announcement__inner">
      {%- if show_nav -%}
        <button class="mg-announcement__arrow mg-announcement__arrow--prev" type="button" aria-label="{{ 'general.accessibility.previous' | t }}" data-mg-prev>
          {%- render 'icon', name: 'chevron-left' -%}
        </button>
      {%- endif -%}

      <div class="mg-announcement__viewport" data-mg-viewport aria-live="polite" aria-atomic="true">
        {%- for block in section.blocks -%}
          <div
            class="mg-announcement__slide {% if forloop.first %}is-active{% endif %}"
            data-mg-slide
            data-index="{{ forloop.index0 }}"
            {{ block.shopify_attributes }}
            {% unless forloop.first %}aria-hidden="true"{% endunless %}
          >
            {%- if block.settings.icon != blank -%}
              <span class="mg-announcement__icon" aria-hidden="true">{%- render 'icon', name: block.settings.icon -%}</span>
            {%- endif -%}

            {%- if block.settings.link != blank -%}<a class="mg-announcement__link" href="{{ block.settings.link }}">{%- endif -%}
              <span class="mg-announcement__text">{{ block.settings.text }}</span>
            {%- if block.settings.link != blank -%}</a>{%- endif -%}

            {%- if block.settings.show_countdown and block.settings.countdown_date != blank -%}
              <mg-countdown class="mg-announcement__countdown" data-deadline="{{ block.settings.countdown_date }}">
                <span class="mg-announcement__countdown-text">&nbsp;</span>
              </mg-countdown>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      {%- if show_nav -%}
        <button class="mg-announcement__arrow mg-announcement__arrow--next" type="button" aria-label="{{ 'general.accessibility.next' | t }}" data-mg-next>
          {%- render 'icon', name: 'chevron-right' -%}
        </button>
      {%- endif -%}

      {%- if section.settings.show_close -%}
        <button class="mg-announcement__close" type="button" aria-label="{{ 'general.accessibility.close' | t }}" data-mg-close>
          {%- render 'icon', name: 'close' -%}
        </button>
      {%- endif -%}
    </div>

    {%- if section.settings.autorotate and block_count > 1 and section.settings.show_dots -%}
      <div class="mg-announcement__dots" role="tablist" aria-label="Announcement navigation">
        {%- for block in section.blocks -%}
          <button
            class="mg-announcement__dot {% if forloop.first %}is-active{% endif %}"
            type="button"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-label="{{ forloop.index }}"
            data-mg-dot
            data-index="{{ forloop.index0 }}"
          ></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </mg-announcement-bar>
{%- endif -%}

{%- comment -%} ---------- CSS (ships only when section is used) ---------- {%- endcomment -%}
{% stylesheet %}
.mg-announcement {
  display: block;
  background: var(--mg-ann-bg, var(--mg-navy));
  color: var(--mg-ann-text, var(--mg-ivory));
  font-family: var(--mg-font-eyebrow);
  font-size: var(--mg-ann-fs, 12px);
  letter-spacing: var(--mg-track-wide);
}
.mg-announcement__inner {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--mg-space-3);
  min-height: var(--mg-ann-height, 40px);
  padding-inline: var(--mg-ann-pad, 16px);
  max-width: var(--mg-container-wide);
  margin-inline: auto;
}
.mg-announcement__viewport {
  position: relative;
  flex: 1 1 auto;
  display: grid;
  place-items: center;
  min-height: inherit;
  overflow: hidden;
}
.mg-announcement__slide {
  grid-area: 1 / 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--mg-space-2);
  width: 100%;
  text-align: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity var(--mg-dur-base) var(--mg-ease);
}
.mg-announcement__slide.is-active { opacity: 1; visibility: visible; }
.mg-announcement[data-animate="true"] .mg-announcement__slide {
  transform: translateY(6px);
  transition: opacity var(--mg-dur-base) var(--mg-ease), transform var(--mg-dur-base) var(--mg-ease);
}
.mg-announcement[data-animate="true"] .mg-announcement__slide.is-active { transform: translateY(0); }
.mg-announcement__text { text-transform: uppercase; }
.mg-announcement__link { color: inherit; text-decoration: none; border-bottom: 1px solid transparent; transition: border-color var(--mg-dur-base) var(--mg-ease); }
.mg-announcement__link:hover { color: inherit; border-bottom-color: currentColor; }
.mg-announcement__icon { display: inline-flex; }
.mg-announcement__icon svg { width: 16px; height: 16px; }
.mg-announcement__countdown { font-variant-numeric: tabular-nums; }

.mg-announcement__arrow,
.mg-announcement__close {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 32px; height: 32px;
  color: inherit;
  opacity: var(--mg-opacity-muted);
  transition: opacity var(--mg-dur-base) var(--mg-ease);
}
.mg-announcement__arrow:hover,
.mg-announcement__close:hover { opacity: 1; }
.mg-announcement__arrow svg,
.mg-announcement__close svg { width: 16px; height: 16px; }
.mg-announcement__close { position: absolute; right: var(--mg-ann-pad, 16px); }

.mg-announcement__dots {
  display: flex;
  justify-content: center;
  gap: var(--mg-space-2);
  padding-bottom: var(--mg-space-2);
}
.mg-announcement__dot {
  width: 6px; height: 6px;
  border-radius: var(--mg-radius-pill);
  background: currentColor;
  opacity: 0.35;
  transition: opacity var(--mg-dur-base) var(--mg-ease);
}
.mg-announcement__dot.is-active { opacity: 1; }

@media (max-width: 767px) {
  .mg-announcement__arrow { display: none; }
  .mg-announcement__close { width: 28px; height: 28px; }
}
{% endstyle %}

{%- comment -%} ---------- JavaScript (custom elements) ---------- {%- endcomment -%}
{% javascript %}
class MGAnnouncementBar extends HTMLElement {
  connectedCallback() {
    this.slides = Array.from(this.querySelectorAll('[data-mg-slide]'));
    this.dots = Array.from(this.querySelectorAll('[data-mg-dot]'));
    this.index = 0;
    this.timer = null;

    if (this._dismissed()) { this.remove(); return; }

    const prev = this.querySelector('[data-mg-prev]');
    const next = this.querySelector('[data-mg-next]');
    const close = this.querySelector('[data-mg-close]');

    if (prev) prev.addEventListener('click', () => this.go(this.index - 1, true));
    if (next) next.addEventListener('click', () => this.go(this.index + 1, true));
    if (close) close.addEventListener('click', () => this.dismiss());
    this.dots.forEach((dot) =>
      dot.addEventListener('click', () => this.go(parseInt(dot.dataset.index, 10), true))
    );

    const reduced = window.MG && MG.utils.prefersReducedMotion();
    if (this.dataset.autorotate === 'true' && this.slides.length > 1 && !reduced) {
      this.speed = parseInt(this.dataset.speed, 10) || 5000;
      this.start();
      if (this.dataset.pauseOnHover === 'true') {
        this.addEventListener('mouseenter', () => this.stop());
        this.addEventListener('mouseleave', () => this.start());
        this.addEventListener('focusin', () => this.stop());
        this.addEventListener('focusout', () => this.start());
      }
    }
  }

  disconnectedCallback() { this.stop(); }

  go(i, userInitiated) {
    const count = this.slides.length;
    if (!count) return;
    this.index = (i + count) % count;
    this.slides.forEach((s, idx) => {
      const active = idx === this.index;
      s.classList.toggle('is-active', active);
      s.setAttribute('aria-hidden', active ? 'false' : 'true');
    });
    this.dots.forEach((d, idx) => {
      const active = idx === this.index;
      d.classList.toggle('is-active', active);
      d.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    if (userInitiated && this.timer) { this.stop(); this.start(); }
  }

  start() {
    if (this.slides.length < 2) return;
    this.stop();
    this.timer = setInterval(() => this.go(this.index + 1), this.speed);
  }
  stop() { if (this.timer) { clearInterval(this.timer); this.timer = null; } }

  _key() { return 'mg-ann-dismissed-' + this.id; }
  _dismissed() { try { return localStorage.getItem(this._key()) === '1'; } catch (e) { return false; } }
  dismiss() {
    try { localStorage.setItem(this._key(), '1'); } catch (e) {}
    this.style.height = this.offsetHeight + 'px';
    requestAnimationFrame(() => {
      this.style.transition = 'height 300ms var(--mg-ease), opacity 300ms var(--mg-ease)';
      this.style.height = '0';
      this.style.opacity = '0';
      this.style.overflow = 'hidden';
    });
    setTimeout(() => this.remove(), 320);
  }
}
if (!customElements.get('mg-announcement-bar')) {
  customElements.define('mg-announcement-bar', MGAnnouncementBar);
}

class MGCountdown extends HTMLElement {
  connectedCallback() {
    this.output = this.querySelector('.mg-announcement__countdown-text');
    this.deadline = new Date(this.dataset.deadline).getTime();
    if (isNaN(this.deadline)) { this.remove(); return; }
    this.tick();
    this.interval = setInterval(() => this.tick(), 1000);
  }
  disconnectedCallback() { if (this.interval) clearInterval(this.interval); }
  tick() {
    const diff = this.deadline - Date.now();
    if (diff <= 0) {
      this.output.textContent = ' — Offer ended';
      clearInterval(this.interval);
      return;
    }
    const d = Math.floor(diff / 86400000);
    const h = Math.floor((diff % 86400000) / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);
    this.output.textContent = ` — ${d}d ${h}h ${m}m ${s}s`;
  }
}
if (!customElements.get('mg-countdown')) {
  customElements.define('mg-countdown', MGCountdown);
}
{% endjavascript %}

{% schema %}
{
  "name": "Announcement bar",
  "tag": "section",
  "class": "mg-announcement-section",
  "settings": [
    { "type": "header", "content": "Behaviour" },
    { "type": "checkbox", "id": "autorotate", "label": "Auto-rotate announcements", "default": true },
    { "type": "range", "id": "rotation_speed", "min": 3, "max": 12, "step": 1, "unit": "s", "label": "Rotation speed", "default": 5 },
    { "type": "checkbox", "id": "pause_on_hover", "label": "Pause on hover", "default": true },
    { "type": "checkbox", "id": "animate", "label": "Animate transitions", "default": true },
    { "type": "checkbox", "id": "show_arrows", "label": "Show navigation arrows", "default": false },
    { "type": "checkbox", "id": "show_dots", "label": "Show navigation dots", "default": false },
    { "type": "checkbox", "id": "show_close", "label": "Show close button", "default": false },

    { "type": "header", "content": "Style" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#1B2A4A" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#F7F4EC" },
    { "type": "range", "id": "font_size", "min": 10, "max": 18, "step": 1, "unit": "px", "label": "Font size", "default": 12 },
    { "type": "range", "id": "height", "min": 32, "max": 80, "step": 2, "unit": "px", "label": "Bar height", "default": 40 },
    { "type": "range", "id": "padding_inline", "min": 8, "max": 64, "step": 2, "unit": "px", "label": "Horizontal padding", "default": 16 },

    { "type": "header", "content": "Visibility" },
    { "type": "checkbox", "id": "show_on_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_on_mobile", "label": "Show on mobile", "default": true },

    { "type": "header", "content": "Advanced" },
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Complimentary shipping on all orders" },
        { "type": "url", "id": "link", "label": "Link" },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "", "label": "None" },
            { "value": "truck", "label": "Shipping" },
            { "value": "gift", "label": "Gift" },
            { "value": "globe", "label": "Globe" },
            { "value": "star", "label": "Star" },
            { "value": "tag", "label": "Tag" }
          ],
          "default": ""
        },
        { "type": "header", "content": "Countdown (optional)" },
        { "type": "checkbox", "id": "show_countdown", "label": "Show countdown", "default": false },
        { "type": "text", "id": "countdown_date", "label": "End date/time", "info": "Format: YYYY-MM-DD HH:MM (e.g. 2026-12-31 23:59)" }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        { "type": "announcement", "settings": { "text": "Complimentary shipping on all orders", "icon": "truck" } },
        { "type": "announcement", "settings": { "text": "Discover the new Heritage Collection", "icon": "star" } }
      ]
    }
  ]
}
{% endschema %}
