{%- comment -%}
  Madrishi Global — Homepage Sections 12 & 13: Featured Brands / Press
  Flexible logo list. Use as a logo strip (brands) or press mentions
  (logos + optional quote). Grid or marquee-style row. No section JS
  beyond optional carousel.
{%- endcomment -%}
<section
  class="mg-logos mg-logos--{{ section.settings.style }} {{ section.settings.custom_class }}"
  id="{{ section.settings.anchor_id | default: section.id }}"
  style="--mg-logos-bg: {{ section.settings.background }}; --mg-logos-text: {{ section.settings.text_color }}; --mg-logos-pad-top: {{ section.settings.padding_top }}px; --mg-logos-pad-bottom: {{ section.settings.padding_bottom }}px; --mg-logos-cols: {{ section.settings.columns }};"
  data-mg-animate-section
>
  <div class="mg-logos__inner mg-container">
    {%- if section.settings.heading != blank or section.settings.eyebrow != blank -%}
      <div class="mg-section-header mg-section-header--center">
        {%- if section.settings.eyebrow != blank -%}<p class="mg-section-header__eyebrow mg-eyebrow" data-mg-animate>{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="mg-section-header__title" data-mg-animate>{{ section.settings.heading | escape }}</h2>{%- endif -%}
      </div>
    {%- endif -%}

    <ul class="mg-logos__grid" role="list" data-mg-animate>
      {%- for block in section.blocks -%}
        <li class="mg-logos__item" {{ block.shopify_attributes }}>
          {%- capture logo -%}
            {%- if block.settings.image != blank -%}
              {%- render 'responsive-image', image: block.settings.image, sizes: '180px', class: 'mg-logos__img', widths: '120,180,240,360' -%}
            {%- elsif block.settings.text != blank -%}
              <span class="mg-logos__name">{{ block.settings.text | escape }}</span>
            {%- endif -%}
          {%- endcapture -%}
          {%- if block.settings.link != blank -%}<a class="mg-logos__link" href="{{ block.settings.link }}" aria-label="{{ block.settings.text | default: 'Brand' | escape }}">{{ logo }}</a>{%- else -%}{{ logo }}{%- endif -%}
          {%- if block.settings.quote != blank -%}<p class="mg-logos__quote">{{ block.settings.quote | escape }}</p>{%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </div>
</section>

{% stylesheet %}
.mg-logos { background: var(--mg-logos-bg, var(--mg-bg-page)); color: var(--mg-logos-text, var(--mg-text)); padding-block: var(--mg-logos-pad-top, var(--mg-space-11)) var(--mg-logos-pad-bottom, var(--mg-space-11)); }
.mg-logos .mg-section-header__title { color: inherit; }
.mg-logos__grid { display: grid; grid-template-columns: repeat(var(--mg-logos-cols, 5), minmax(0, 1fr)); gap: var(--mg-space-8); align-items: center; }
.mg-logos__item { display: flex; flex-direction: column; align-items: center; gap: var(--mg-space-3); text-align: center; }
.mg-logos__link, .mg-logos__img { display: block; }
.mg-logos__img { max-height: 56px; width: auto; margin-inline: auto; opacity: 0.7; filter: grayscale(1); transition: opacity var(--mg-dur-base) var(--mg-ease), filter var(--mg-dur-base) var(--mg-ease); }
.mg-logos__item:hover .mg-logos__img { opacity: 1; filter: grayscale(0); }
.mg-logos__name { font-family: var(--mg-font-display); font-size: var(--mg-fs-card-heading); color: inherit; }
.mg-logos__quote { font-size: var(--mg-fs-caption); font-style: italic; color: var(--mg-text-secondary); max-width: 22ch; }
.mg-logos--press .mg-logos__grid { gap: var(--mg-space-9); }
[data-mg-animate-section] [data-mg-animate] { opacity: 0; transform: translateY(16px); transition: opacity var(--mg-dur-slow) var(--mg-ease), transform var(--mg-dur-slow) var(--mg-ease); }
[data-mg-animate-section].is-revealed [data-mg-animate] { opacity: 1; transform: none; }
@media (max-width: 989px) { .mg-logos__grid { grid-template-columns: repeat(3, 1fr); gap: var(--mg-space-6); } }
@media (max-width: 600px) { .mg-logos__grid { grid-template-columns: repeat(2, 1fr); } }
@media (prefers-reduced-motion: reduce) { [data-mg-animate-section] [data-mg-animate] { opacity: 1 !important; transform: none !important; } }
{% endstyle %}

{% schema %}
{
  "name": "Logo list",
  "tag": "section",
  "class": "mg-logos-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "As seen in" },
    { "type": "select", "id": "style", "label": "Style", "options": [ { "value": "brands", "label": "Brands (logos)" }, { "value": "press", "label": "Press (logos + quotes)" } ], "default": "press" },
    { "type": "range", "id": "columns", "min": 2, "max": 6, "step": 1, "label": "Columns", "default": 5 },
    { "type": "color", "id": "background", "label": "Background", "default": "#FBF8F2" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#1C1C1C" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 200, "step": 8, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 200, "step": 8, "unit": "px", "label": "Padding bottom", "default": 80 },
    { "type": "text", "id": "anchor_id", "label": "Section anchor ID" },
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Logo image" },
        { "type": "text", "id": "text", "label": "Name", "info": "Used if no image" },
        { "type": "text", "id": "quote", "label": "Quote (press)" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [ { "name": "Logo list", "blocks": [ { "type": "logo" }, { "type": "logo" }, { "type": "logo" }, { "type": "logo" }, { "type": "logo" } ] } ]
}
{% endschema %}
