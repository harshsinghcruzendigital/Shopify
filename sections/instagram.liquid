{%- comment -%}
  Madrishi Global — Homepage Section 16: Instagram Feed
  Curated responsive image grid (manual blocks — no third-party API).
  Each tile links out and reveals an Instagram glyph on hover. No JS.
{%- endcomment -%}
<section
  class="mg-ig {{ section.settings.custom_class }}"
  id="{{ section.settings.anchor_id | default: section.id }}"
  style="--mg-ig-bg: {{ section.settings.background }}; --mg-ig-text: {{ section.settings.text_color }}; --mg-ig-pad-top: {{ section.settings.padding_top }}px; --mg-ig-pad-bottom: {{ section.settings.padding_bottom }}px; --mg-ig-cols: {{ section.settings.columns }};"
  data-mg-animate-section
>
  <div class="mg-ig__inner mg-container">
    <div class="mg-section-header mg-section-header--center">
      {%- if section.settings.eyebrow != blank -%}<p class="mg-section-header__eyebrow mg-eyebrow" data-mg-animate>{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="mg-section-header__title" data-mg-animate>{{ section.settings.heading | escape }}</h2>{%- endif -%}
      {%- if section.settings.handle != blank -%}<a class="mg-ig__handle" href="{{ section.settings.handle_link | default: '#' }}" data-mg-animate>{{ section.settings.handle | escape }}</a>{%- endif -%}
    </div>

    <ul class="mg-ig__grid" role="list" data-mg-animate>
      {%- for block in section.blocks -%}
        <li class="mg-ig__item" {{ block.shopify_attributes }}>
          <a class="mg-ig__link" href="{{ block.settings.link | default: section.settings.handle_link | default: '#' }}" target="_blank" rel="noopener" aria-label="{{ 'general.accessibility.instagram' | t | default: 'View on Instagram' }}">
            {%- if block.settings.image != blank -%}
              {%- render 'responsive-image', image: block.settings.image, sizes: '(min-width:768px) 16vw, 50vw', class: 'mg-ig__img', aspect_ratio: '1/1' -%}
            {%- else -%}
              <div class="mg-image-placeholder" style="aspect-ratio:1/1;">{{ 'image' | placeholder_svg_tag }}</div>
            {%- endif -%}
            <span class="mg-ig__overlay" aria-hidden="true">{%- render 'icon', name: 'instagram', size: 24 -%}</span>
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</section>

{% stylesheet %}
.mg-ig { background: var(--mg-ig-bg, var(--mg-bg-page)); color: var(--mg-ig-text, var(--mg-text)); padding-block: var(--mg-ig-pad-top, var(--mg-section-spacing)) var(--mg-ig-pad-bottom, var(--mg-section-spacing)); }
.mg-ig .mg-section-header__title { color: inherit; }
.mg-ig__handle { display: inline-block; margin-top: var(--mg-space-2); font-family: var(--mg-font-eyebrow); font-size: var(--mg-fs-caption); letter-spacing: var(--mg-track-wide); text-transform: uppercase; color: var(--mg-gold); }
.mg-ig__grid { display: grid; grid-template-columns: repeat(var(--mg-ig-cols, 6), minmax(0, 1fr)); gap: var(--mg-space-2); }
.mg-ig__link { position: relative; display: block; overflow: hidden; }
.mg-ig__img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--mg-dur-slow) var(--mg-ease); }
.mg-ig__link:hover .mg-ig__img { transform: scale(1.06); }
.mg-ig__overlay { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; color: var(--mg-ivory); background: var(--mg-overlay); opacity: 0; transition: opacity var(--mg-dur-base) var(--mg-ease); }
.mg-ig__link:hover .mg-ig__overlay, .mg-ig__link:focus-visible .mg-ig__overlay { opacity: 1; }
[data-mg-animate-section] [data-mg-animate] { opacity: 0; transform: translateY(16px); transition: opacity var(--mg-dur-slow) var(--mg-ease), transform var(--mg-dur-slow) var(--mg-ease); }
[data-mg-animate-section].is-revealed [data-mg-animate] { opacity: 1; transform: none; }
@media (max-width: 989px) { .mg-ig__grid { grid-template-columns: repeat(4, 1fr); } }
@media (max-width: 600px) { .mg-ig__grid { grid-template-columns: repeat(2, 1fr); } }
@media (prefers-reduced-motion: reduce) { [data-mg-animate-section] [data-mg-animate] { opacity: 1 !important; transform: none !important; } }
{% endstyle %}

{% schema %}
{
  "name": "Instagram",
  "tag": "section",
  "class": "mg-ig-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "@madrishiglobal" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Follow the Journey" },
    { "type": "text", "id": "handle", "label": "Handle text", "default": "@madrishiglobal" },
    { "type": "url", "id": "handle_link", "label": "Instagram URL" },
    { "type": "range", "id": "columns", "min": 3, "max": 8, "step": 1, "label": "Columns", "default": 6 },
    { "type": "color", "id": "background", "label": "Background", "default": "#FBF8F2" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#1C1C1C" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 200, "step": 8, "unit": "px", "label": "Padding top", "default": 96 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 200, "step": 8, "unit": "px", "label": "Padding bottom", "default": 96 },
    { "type": "text", "id": "anchor_id", "label": "Section anchor ID" },
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" }
  ],
  "blocks": [
    { "type": "post", "name": "Post", "settings": [ { "type": "image_picker", "id": "image", "label": "Image" }, { "type": "url", "id": "link", "label": "Link" } ] }
  ],
  "max_blocks": 12,
  "presets": [ { "name": "Instagram", "blocks": [ { "type": "post" }, { "type": "post" }, { "type": "post" }, { "type": "post" }, { "type": "post" }, { "type": "post" } ] } ]
}
{% endschema %}
