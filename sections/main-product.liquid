{%- comment -%}
  ============================================================
  Madrishi Global — Product Page · Main Product
  Media gallery + buy box: variant picker, quantity, add-to-cart
  (feeds cart drawer), wishlist, share, description, accordion blocks.
  Product JSON-LD for SEO. Custom elements: <mg-product-gallery>,
  <mg-product-form> (product.js, loaded here).
  ============================================================
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign on_sale = false
  if current_variant.compare_at_price > current_variant.price
    assign on_sale = true
  endif
-%}

<section class="mg-product mg-section {{ section.settings.custom_class }}" id="MainProduct-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="mg-product__grid mg-container">

    {%- comment -%} ---------- Media gallery ---------- {%- endcomment -%}
    <mg-product-gallery class="mg-product__media">
      <div class="mg-product__stage">
        {%- if product.media.size > 0 -%}
          {%- for media in product.media -%}
            <div class="mg-product__media-item {% if forloop.first %}is-active{% endif %}" data-mg-media data-media-id="{{ media.id }}" {% unless forloop.first %}aria-hidden="true"{% endunless %}>
              {%- case media.media_type -%}
                {%- when 'image' -%}
                  {%- assign eager = false -%}{%- if forloop.first -%}{%- assign eager = true -%}{%- endif -%}
                  {%- render 'responsive-image', image: media.preview_image, sizes: '(min-width:990px) 50vw, 100vw', class: 'mg-product__img', loading: eager | default: 'lazy', fetchpriority: eager | default: '', aspect_ratio: section.settings.image_ratio -%}
                {%- when 'video' -%}
                  {{ media | media_tag: image_size: '1200x', class: 'mg-product__video' }}
                {%- when 'external_video' -%}
                  {{ media | external_video_tag: class: 'mg-product__video' }}
                {%- else -%}
                  {%- render 'responsive-image', image: media.preview_image, sizes: '50vw', class: 'mg-product__img', aspect_ratio: section.settings.image_ratio -%}
              {%- endcase -%}
            </div>
          {%- endfor -%}
        {%- else -%}
          <div class="mg-product__media-item is-active"><div class="mg-image-placeholder" style="aspect-ratio: {{ section.settings.image_ratio }};">{{ 'product-1' | placeholder_svg_tag }}</div></div>
        {%- endif -%}
      </div>

      {%- if product.media.size > 1 -%}
        <div class="mg-product__thumbs" role="list">
          {%- for media in product.media -%}
            <button class="mg-product__thumb {% if forloop.first %}is-active{% endif %}" type="button" data-mg-thumb data-index="{{ forloop.index0 }}" aria-label="{{ 'products.media.view' | t | default: 'View media' }} {{ forloop.index }}" {% if forloop.first %}aria-current="true"{% endif %}>
              {%- render 'responsive-image', image: media.preview_image, sizes: '88px', class: 'mg-product__thumb-img', widths: '88,176', aspect_ratio: '1/1' -%}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </mg-product-gallery>

    {%- comment -%} ---------- Buy box ---------- {%- endcomment -%}
    <div class="mg-product__info">
      {%- if section.settings.show_breadcrumb -%}{%- render 'breadcrumbs', class: 'mg-product__breadcrumb' -%}{%- endif -%}

      {%- if section.settings.show_vendor and product.vendor != blank -%}<p class="mg-product__vendor">{{ product.vendor | escape }}</p>{%- endif -%}
      <h1 class="mg-product__title">{{ product.title | escape }}</h1>

      {%- if product.metafields.reviews.rating.value != blank -%}
        {%- assign rounded = product.metafields.reviews.rating.value.rating | round -%}
        <div class="mg-product__rating" role="img" aria-label="{{ product.metafields.reviews.rating.value.rating }} {{ 'products.card.out_of_5' | t }}">
          <span aria-hidden="true">{% for i in (1..5) %}{% if i <= rounded %}★{% else %}☆{% endif %}{% endfor %}</span>
          {%- if product.metafields.reviews.rating_count.value -%}<span class="mg-product__rating-count">({{ product.metafields.reviews.rating_count.value }})</span>{%- endif -%}
        </div>
      {%- endif -%}

      <div class="mg-product__price">
        <span class="mg-product__price-current {% if on_sale %}is-sale{% endif %}" data-mg-price-current>{{ current_variant.price | money }}</span>
        <s class="mg-product__price-compare" data-mg-price-compare {% unless on_sale %}hidden{% endunless %}>{{ current_variant.compare_at_price | money }}</s>
      </div>

      <mg-product-form class="mg-product__form-wrap">
        <script type="application/json" data-mg-variants>
          [
            {%- for v in product.variants -%}
              {"id": {{ v.id }}, "available": {{ v.available }}, "options": {{ v.options | json }}, "price": {{ v.price | money | json }}, "compare_at_price": {{ v.compare_at_price | money | json }}, "on_sale": {% if v.compare_at_price > v.price %}true{% else %}false{% endif %}, "media_id": {{ v.featured_media.id | default: 'null' }}}{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
          ]
        </script>

        {%- form 'product', product, id: 'product-form-' | append: section.id, class: 'mg-product__form', novalidate: 'novalidate' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-mg-variant-id>

          {%- render 'variant-picker', product: product -%}

          {%- if section.settings.show_quantity -%}
            <div class="mg-product__qty-row">
              <span class="mg-product__qty-label">{{ 'cart.quantity' | t }}</span>
              <div class="mg-product__qty">
                <button class="mg-product__qty-btn" type="button" data-mg-qty-down aria-label="{{ 'cart.decrease' | t }}">{%- render 'icon', name: 'minus', size: 14 -%}</button>
                <input class="mg-product__qty-input" type="number" name="quantity" value="1" min="1" data-mg-qty aria-label="{{ 'cart.quantity' | t }}">
                <button class="mg-product__qty-btn" type="button" data-mg-qty-up aria-label="{{ 'cart.increase' | t }}">{%- render 'icon', name: 'plus', size: 14 -%}</button>
              </div>
            </div>
          {%- endif -%}

          <div class="mg-product__buy">
            <button
              type="submit"
              class="mg-btn mg-btn--primary mg-product__atc"
              data-mg-atc
              data-label-add="{{ 'products.add_to_cart' | t | default: 'Add to cart' }}"
              data-label-soldout="{{ 'products.sold_out' | t | default: 'Sold out' }}"
              data-label-unavailable="{{ 'products.unavailable' | t | default: 'Unavailable' }}"
              {% unless current_variant.available %}disabled{% endunless %}
            >
              <span data-mg-atc-text>{% if current_variant.available %}{{ 'products.add_to_cart' | t | default: 'Add to cart' }}{% else %}{{ 'products.sold_out' | t | default: 'Sold out' }}{% endif %}</span>
            </button>
            {%- if section.settings.show_wishlist -%}
              <button class="mg-btn mg-btn--icon mg-product__wishlist" type="button" aria-label="{{ 'products.card.add_wishlist' | t }}" data-mg-wishlist-toggle data-product-handle="{{ product.handle }}">{%- render 'icon', name: 'heart', size: 20 -%}</button>
            {%- endif -%}
          </div>
          <div class="mg-product__error" data-mg-cart-error role="alert"></div>
        {%- endform -%}
      </mg-product-form>

      {%- if product.description != blank -%}
        <div class="mg-product__description rte">{{ product.description }}</div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="mg-product__accordions">
          {%- for block in section.blocks -%}
            {%- if block.type == 'accordion' -%}
              <details class="mg-product__accordion" {{ block.shopify_attributes }} {% if block.settings.open %}open{% endif %}>
                <summary class="mg-product__accordion-summary">{{ block.settings.heading | escape }}{%- render 'icon', name: 'chevron-down', size: 16 -%}</summary>
                <div class="mg-product__accordion-body rte">{{ block.settings.content }}</div>
              </details>
            {%- elsif block.type == 'share' -%}
              <div class="mg-product__share" {{ block.shopify_attributes }}>
                <span class="mg-product__share-label">{{ block.settings.heading | default: 'Share' | escape }}</span>
                {%- render 'social-icons' -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} ---------- Product JSON-LD ---------- {%- endcomment -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org/",
      "@type": "Product",
      "name": {{ product.title | json }},
      "description": {{ product.description | strip_html | truncatewords: 60 | json }},
      "image": [{%- for media in product.media limit: 3 -%}{{ media.preview_image | image_url: width: 1200 | prepend: 'https:' | json }}{% unless forloop.last %},{% endunless %}{%- endfor -%}],
      "brand": { "@type": "Brand", "name": {{ product.vendor | json }} },
      "sku": {{ current_variant.sku | json }},
      "offers": {
        "@type": "Offer",
        "price": {{ current_variant.price | divided_by: 100.0 | json }},
        "priceCurrency": {{ cart.currency.iso_code | json }},
        "availability": "https://schema.org/{% if current_variant.available %}InStock{% else %}OutOfStock{% endif %}",
        "url": {{ request.origin | append: product.url | json }}
      }
    }
  </script>
</section>

<script src="{{ 'product.js' | asset_url }}" defer="defer"></script>

{% stylesheet %}
.mg-product__grid { display: grid; gap: var(--mg-space-9); }
@media (min-width: 990px) { .mg-product__grid { grid-template-columns: 1.1fr 0.9fr; gap: var(--mg-space-12); align-items: start; } }

/* Gallery */
.mg-product__media { display: block; }
.mg-product__stage { position: relative; }
.mg-product__media-item { display: none; }
.mg-product__media-item.is-active { display: block; }
.mg-product__img, .mg-product__video { width: 100%; height: auto; display: block; }
.mg-product__thumbs { display: flex; gap: var(--mg-space-2); margin-top: var(--mg-space-3); flex-wrap: wrap; }
.mg-product__thumb { width: 72px; height: 72px; overflow: hidden; border: var(--mg-border-hairline) solid transparent; opacity: 0.7; transition: opacity var(--mg-dur-base) var(--mg-ease), border-color var(--mg-dur-base) var(--mg-ease); }
.mg-product__thumb.is-active, .mg-product__thumb:hover { opacity: 1; border-color: var(--mg-gold); }
.mg-product__thumb-img { width: 100%; height: 100%; object-fit: cover; }

/* Info */
.mg-product__info { display: flex; flex-direction: column; }
@media (min-width: 990px) { .mg-product__info { position: sticky; top: calc(var(--mg-header-current-height, 80px) + var(--mg-space-5)); } }
.mg-product__breadcrumb { margin-bottom: var(--mg-space-4); }
.mg-product__vendor { font-family: var(--mg-font-eyebrow); font-size: var(--mg-fs-caption); letter-spacing: var(--mg-track-wide); text-transform: uppercase; color: var(--mg-text-muted); margin-bottom: var(--mg-space-2); }
.mg-product__title { font-size: var(--mg-fs-section); font-weight: 300; line-height: var(--mg-lh-heading); margin-bottom: var(--mg-space-3); }
.mg-product__rating { color: var(--mg-gold); letter-spacing: 2px; margin-bottom: var(--mg-space-3); }
.mg-product__rating-count { color: var(--mg-text-muted); font-size: var(--mg-fs-caption); margin-left: var(--mg-space-1); }
.mg-product__price { display: flex; align-items: baseline; gap: var(--mg-space-3); margin-bottom: var(--mg-space-6); }
.mg-product__price-current { font-size: var(--mg-fs-collection-title); font-family: var(--mg-font-display); }
.mg-product__price-current.is-sale { color: var(--mg-error); }
.mg-product__price-compare { color: var(--mg-text-muted); }

/* Variants */
.mg-variants__group { border: 0; padding: 0; margin: 0 0 var(--mg-space-5); }
.mg-variants__legend { font-family: var(--mg-font-eyebrow); font-size: var(--mg-fs-caption); font-weight: 600; letter-spacing: var(--mg-track-wide); text-transform: uppercase; margin-bottom: var(--mg-space-3); padding: 0; }
.mg-variants__selected { color: var(--mg-text-muted); margin-left: var(--mg-space-2); }
.mg-variants__options { display: flex; flex-wrap: wrap; gap: var(--mg-space-2); }
.mg-variants__option { cursor: pointer; }
.mg-variants__option input { position: absolute; opacity: 0; width: 0; height: 0; }
.mg-variants__pill { display: inline-flex; align-items: center; justify-content: center; min-width: 48px; min-height: 44px; padding: 0 var(--mg-space-4); border: var(--mg-border-hairline) solid var(--mg-border-input); font-size: var(--mg-fs-body-sm); transition: border-color var(--mg-dur-base) var(--mg-ease), background var(--mg-dur-base) var(--mg-ease); }
.mg-variants__option input:checked + .mg-variants__pill { border-color: var(--mg-navy); background: var(--mg-navy); color: var(--mg-ivory); }
.mg-variants__option input:focus-visible + .mg-variants__pill { outline: var(--mg-border-thick) solid var(--mg-gold); outline-offset: 2px; }
.mg-variants__swatch { display: block; width: 36px; height: 36px; border-radius: 50%; border: var(--mg-border-hairline) solid var(--mg-border-divider); background-size: cover; background-position: center; transition: box-shadow var(--mg-dur-base) var(--mg-ease); }
.mg-variants__option input:checked + .mg-variants__swatch { box-shadow: 0 0 0 2px var(--mg-white), 0 0 0 4px var(--mg-navy); }
.mg-variants__option input:focus-visible + .mg-variants__swatch { box-shadow: 0 0 0 2px var(--mg-white), 0 0 0 4px var(--mg-gold); }

/* Quantity + buy */
.mg-product__qty-row { display: flex; align-items: center; gap: var(--mg-space-4); margin-bottom: var(--mg-space-5); }
.mg-product__qty-label { font-family: var(--mg-font-eyebrow); font-size: var(--mg-fs-caption); letter-spacing: var(--mg-track-wide); text-transform: uppercase; }
.mg-product__qty { display: inline-flex; align-items: center; border: var(--mg-border-hairline) solid var(--mg-border-input); }
.mg-product__qty-btn { width: 44px; height: 48px; display: inline-flex; align-items: center; justify-content: center; }
.mg-product__qty-input { width: 48px; height: 48px; text-align: center; border: 0; border-inline: var(--mg-border-hairline) solid var(--mg-border-input); -moz-appearance: textfield; }
.mg-product__qty-input::-webkit-outer-spin-button, .mg-product__qty-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
.mg-product__buy { display: flex; gap: var(--mg-space-3); }
.mg-product__atc { flex: 1; }
.mg-product__wishlist { border: var(--mg-border-hairline) solid var(--mg-border-input); width: 52px; }
.mg-product__wishlist.is-active { color: var(--mg-gold); }
.mg-product__error:empty { display: none; }
.mg-product__error { color: var(--mg-error); font-size: var(--mg-fs-body-sm); margin-top: var(--mg-space-3); }

/* Description + accordions */
.mg-product__description { margin-top: var(--mg-space-7); color: var(--mg-text-secondary); line-height: var(--mg-lh-body); }
.mg-product__accordions { margin-top: var(--mg-space-7); border-top: var(--mg-border-hairline) solid var(--mg-border-divider); }
.mg-product__accordion { border-bottom: var(--mg-border-hairline) solid var(--mg-border-divider); }
.mg-product__accordion-summary { display: flex; align-items: center; justify-content: space-between; padding: var(--mg-space-4) 0; cursor: pointer; font-family: var(--mg-font-eyebrow); font-size: var(--mg-fs-nav); letter-spacing: var(--mg-track-wide); text-transform: uppercase; list-style: none; }
.mg-product__accordion-summary::-webkit-details-marker { display: none; }
.mg-product__accordion-summary svg { transition: transform var(--mg-dur-base) var(--mg-ease); }
.mg-product__accordion[open] .mg-product__accordion-summary svg { transform: rotate(180deg); }
.mg-product__accordion-body { padding-bottom: var(--mg-space-5); color: var(--mg-text-secondary); line-height: var(--mg-lh-body); }
.mg-product__share { display: flex; align-items: center; gap: var(--mg-space-3); padding: var(--mg-space-5) 0; }
.mg-product__share-label { font-family: var(--mg-font-eyebrow); font-size: var(--mg-fs-caption); letter-spacing: var(--mg-track-wide); text-transform: uppercase; }
{% endstyle %}

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "class": "mg-product-section",
  "settings": [
    { "type": "header", "content": "Gallery" },
    { "type": "select", "id": "image_ratio", "label": "Image ratio", "options": [ { "value": "3/4", "label": "Portrait (3:4)" }, { "value": "4/5", "label": "Portrait (4:5)" }, { "value": "1/1", "label": "Square" } ], "default": "4/5" },
    { "type": "header", "content": "Buy box" },
    { "type": "checkbox", "id": "show_breadcrumb", "label": "Show breadcrumb", "default": true },
    { "type": "checkbox", "id": "show_vendor", "label": "Show vendor", "default": true },
    { "type": "checkbox", "id": "show_quantity", "label": "Show quantity selector", "default": true },
    { "type": "checkbox", "id": "show_wishlist", "label": "Show wishlist button", "default": true },
    { "type": "header", "content": "Advanced" },
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Details" },
        { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Add product details, materials and care instructions.</p>" },
        { "type": "checkbox", "id": "open", "label": "Open by default", "default": false }
      ]
    },
    { "type": "share", "name": "Share", "limit": 1, "settings": [ { "type": "text", "id": "heading", "label": "Label", "default": "Share" } ] }
  ],
  "enabled_on": { "templates": ["product"] }
}
{% endschema %}
