{%- comment -%}
  ============================================================
  Madrishi Global — Editorial Banner
  Full-bleed lifestyle banner: image or video + overlay, eyebrow,
  heading, rich text and up to two CTAs. 9-position content placement.
  Reusable between collection products and across the homepage.
  No section JS — uses shared scroll-reveal observer.
  ============================================================
{%- endcomment -%}

{%- liquid
  case section.settings.height
    when 'small'  assign height_css = '40svh'
    when 'medium' assign height_css = '60svh'
    when 'large'  assign height_css = '80svh'
    when 'full'   assign height_css = '100svh'
    else          assign height_css = section.settings.custom_height | append: 'px'
  endcase
-%}

<section
  class="mg-editorial mg-editorial--{{ section.settings.content_x }} mg-editorial--v-{{ section.settings.content_y }} {% if section.settings.full_width %}mg-editorial--full{% endif %} {{ section.settings.custom_class }}"
  id="{{ section.settings.anchor_id | default: section.id }}"
  style="--mg-editorial-height: {{ height_css }};"
  {% if section.settings.animate %}data-mg-animate-section{% endif %}
>
  <div class="mg-editorial__frame {% unless section.settings.full_width %}mg-container{% endunless %}">
    <div class="mg-editorial__media">
      {%- if section.settings.video != blank -%}
        {{ section.settings.video | video_tag: image_size: '1100x', loop: true, autoplay: true, muted: true, controls: false, class: 'mg-editorial__video' }}
      {%- elsif section.settings.image != blank -%}
        {%- render 'responsive-image', image: section.settings.image, mobile: section.settings.image_mobile, sizes: '100vw', class: 'mg-editorial__img' -%}
      {%- else -%}
        <div class="mg-editorial__placeholder">{{ 'lifestyle-2' | placeholder_svg_tag }}</div>
      {%- endif -%}
      {%- if section.settings.overlay_opacity > 0 -%}
        <span class="mg-editorial__overlay" style="background: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};" aria-hidden="true"></span>
      {%- endif -%}
    </div>

    <div class="mg-editorial__content-wrap mg-container">
      <div class="mg-editorial__content" style="--mg-editorial-text: {{ section.settings.text_color }}; max-width: {{ section.settings.content_width }}px;">
        {%- if section.settings.eyebrow != blank -%}
          <p class="mg-editorial__eyebrow mg-eyebrow" data-mg-animate>{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="mg-editorial__heading" data-mg-animate>{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.body != blank -%}
          <div class="mg-editorial__body rte" data-mg-animate>{{ section.settings.body }}</div>
        {%- endif -%}
        {%- if section.settings.button_1_text != blank or section.settings.button_2_text != blank -%}
          <div class="mg-editorial__actions" data-mg-animate>
            {%- if section.settings.button_1_text != blank -%}
              <a class="mg-btn mg-btn--{{ section.settings.button_1_style }}" href="{{ section.settings.button_1_link | default: '#' }}">{{ section.settings.button_1_text | escape }}</a>
            {%- endif -%}
            {%- if section.settings.button_2_text != blank -%}
              <a class="mg-btn mg-btn--{{ section.settings.button_2_style }}" href="{{ section.settings.button_2_link | default: '#' }}">{{ section.settings.button_2_text | escape }}</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
.mg-editorial { position: relative; }
.mg-editorial__frame { position: relative; min-height: var(--mg-editorial-height, 60svh); display: flex; overflow: hidden; background: var(--mg-navy-deep); }
.mg-editorial--full .mg-editorial__frame { width: 100%; }

.mg-editorial__media { position: absolute; inset: 0; z-index: 0; }
.mg-editorial__media .mg-picture, .mg-editorial__img, .mg-editorial__video, .mg-editorial__placeholder { width: 100%; height: 100%; }
.mg-editorial__img, .mg-editorial__video { object-fit: cover; }
.mg-editorial__overlay { position: absolute; inset: 0; }

.mg-editorial__content-wrap { position: relative; z-index: 1; display: flex; width: 100%; padding-block: var(--mg-space-10); }
.mg-editorial__content { color: var(--mg-editorial-text, var(--mg-ivory)); }
.mg-editorial__eyebrow { margin-bottom: var(--mg-space-3); }
.mg-editorial__heading { font-size: var(--mg-fs-section); font-weight: 300; line-height: var(--mg-lh-tight); color: inherit; margin-bottom: var(--mg-space-4); }
.mg-editorial__body { font-size: var(--mg-fs-body-lg); line-height: var(--mg-lh-body); color: inherit; max-width: 56ch; }
.mg-editorial__actions { display: flex; flex-wrap: wrap; gap: var(--mg-space-4); margin-top: var(--mg-space-6); }

/* Horizontal placement */
.mg-editorial--left .mg-editorial__content-wrap { justify-content: flex-start; text-align: left; }
.mg-editorial--center .mg-editorial__content-wrap { justify-content: center; text-align: center; }
.mg-editorial--right .mg-editorial__content-wrap { justify-content: flex-end; text-align: right; }
.mg-editorial--center .mg-editorial__body, .mg-editorial--center .mg-editorial__actions { margin-inline: auto; }
.mg-editorial--center .mg-editorial__actions { justify-content: center; }
.mg-editorial--right .mg-editorial__body { margin-left: auto; }
.mg-editorial--right .mg-editorial__actions { justify-content: flex-end; }

/* Vertical placement */
.mg-editorial--v-top .mg-editorial__content-wrap { align-items: flex-start; }
.mg-editorial--v-middle .mg-editorial__content-wrap { align-items: center; }
.mg-editorial--v-bottom .mg-editorial__content-wrap { align-items: flex-end; }

/* Reveal */
[data-mg-animate-section] .mg-editorial__content [data-mg-animate] { opacity: 0; transform: translateY(20px); transition: opacity var(--mg-dur-slow) var(--mg-ease), transform var(--mg-dur-slow) var(--mg-ease); }
[data-mg-animate-section].is-revealed .mg-editorial__content [data-mg-animate] { opacity: 1; transform: none; }
[data-mg-animate-section].is-revealed .mg-editorial__heading { transition-delay: 80ms; }
[data-mg-animate-section].is-revealed .mg-editorial__body { transition-delay: 160ms; }
[data-mg-animate-section].is-revealed .mg-editorial__actions { transition-delay: 240ms; }

@media (max-width: 767px) {
  .mg-editorial__heading { font-size: var(--mg-fs-card-heading); }
  .mg-editorial__content-wrap { padding-block: var(--mg-space-8); }
}
@media (prefers-reduced-motion: reduce) {
  [data-mg-animate-section] [data-mg-animate] { opacity: 1 !important; transform: none !important; }
}
{% endstyle %}

{% schema %}
{
  "name": "Editorial banner",
  "tag": "section",
  "class": "mg-editorial-section",
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "checkbox", "id": "full_width", "label": "Full width", "default": true },
    { "type": "select", "id": "height", "label": "Height", "options": [ { "value": "small", "label": "Small" }, { "value": "medium", "label": "Medium" }, { "value": "large", "label": "Large" }, { "value": "full", "label": "Full screen" }, { "value": "custom", "label": "Custom" } ], "default": "medium" },
    { "type": "range", "id": "custom_height", "min": 300, "max": 900, "step": 20, "unit": "px", "label": "Custom height", "default": 520 },
    { "type": "select", "id": "content_x", "label": "Horizontal position", "options": [ { "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" } ], "default": "left" },
    { "type": "select", "id": "content_y", "label": "Vertical position", "options": [ { "value": "top", "label": "Top" }, { "value": "middle", "label": "Middle" }, { "value": "bottom", "label": "Bottom" } ], "default": "bottom" },
    { "type": "range", "id": "content_width", "min": 360, "max": 820, "step": 20, "unit": "px", "label": "Content width", "default": 560 },

    { "type": "header", "content": "Media" },
    { "type": "image_picker", "id": "image", "label": "Desktop image" },
    { "type": "image_picker", "id": "image_mobile", "label": "Mobile image" },
    { "type": "video", "id": "video", "label": "Background video", "info": "Overrides image" },
    { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#11182B" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 80, "step": 5, "unit": "%", "label": "Overlay opacity", "default": 30 },

    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Heritage Collection" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>An ode to timeless craftsmanship, reimagined for the modern world.</p>" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#F7F4EC" },

    { "type": "header", "content": "Button 1" },
    { "type": "text", "id": "button_1_text", "label": "Label", "default": "Explore" },
    { "type": "url", "id": "button_1_link", "label": "Link" },
    { "type": "select", "id": "button_1_style", "label": "Style", "options": [ { "value": "primary", "label": "Primary" }, { "value": "secondary", "label": "Secondary" }, { "value": "outline", "label": "Outline" }, { "value": "ghost", "label": "Ghost" } ], "default": "primary" },

    { "type": "header", "content": "Button 2" },
    { "type": "text", "id": "button_2_text", "label": "Label" },
    { "type": "url", "id": "button_2_link", "label": "Link" },
    { "type": "select", "id": "button_2_style", "label": "Style", "options": [ { "value": "primary", "label": "Primary" }, { "value": "secondary", "label": "Secondary" }, { "value": "outline", "label": "Outline" }, { "value": "ghost", "label": "Ghost" } ], "default": "outline" },

    { "type": "header", "content": "Advanced" },
    { "type": "checkbox", "id": "animate", "label": "Animate on scroll", "default": true },
    { "type": "text", "id": "anchor_id", "label": "Section anchor ID" },
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" }
  ],
  "presets": [ { "name": "Editorial banner" } ]
}
{% endschema %}
