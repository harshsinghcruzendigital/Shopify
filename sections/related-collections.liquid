{%- comment -%}
  ============================================================
  Madrishi Global — Related Collections
  Luxury collection-card grid (or carousel) of hand-picked
  collections. Reuses collection-card. Works on collection page and
  homepage (Featured Collections). No section JS beyond shared carousel.
  ============================================================
{%- endcomment -%}

{%- liquid
  assign is_carousel = false
  if section.settings.layout == 'carousel'
    assign is_carousel = true
  endif
  assign cols = section.settings.columns
  assign card_w = 100 | divided_by: cols
-%}

<section
  class="mg-related {{ section.settings.custom_class }}"
  id="{{ section.settings.anchor_id | default: section.id }}"
  style="
    --mg-related-bg: {{ section.settings.background }};
    --mg-related-text: {{ section.settings.text_color }};
    --mg-related-pad-top: {{ section.settings.padding_top }}px;
    --mg-related-pad-bottom: {{ section.settings.padding_bottom }}px;
    --mg-cols: {{ cols }};
    --mg-carousel-item-d: calc({{ card_w }}% - var(--mg-space-5));
  "
  {% if section.settings.animate %}data-mg-animate-section{% endif %}
>
  <div class="mg-related__inner mg-container">
    {%- if section.settings.heading != blank or section.settings.eyebrow != blank -%}
      <div class="mg-related__header mg-section-header mg-section-header--center">
        {%- if section.settings.eyebrow != blank -%}<p class="mg-section-header__eyebrow mg-eyebrow" data-mg-animate>{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="mg-section-header__title" data-mg-animate>{{ section.settings.heading | escape }}</h2>{%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      {%- if is_carousel -%}
        <mg-carousel class="mg-carousel" data-mg-animate>
          <button class="mg-carousel__arrow mg-carousel__arrow--prev" type="button" data-mg-carousel-prev aria-label="{{ 'general.accessibility.previous' | t }}">{%- render 'icon', name: 'chevron-left' -%}</button>
          <ul class="mg-carousel__track" data-mg-carousel-track role="list">
            {%- for block in section.blocks -%}
              {%- if block.settings.collection != blank -%}
                <li {{ block.shopify_attributes }}>
                  {%- render 'collection-card', collection: block.settings.collection, image_override: block.settings.image, heading: block.settings.heading, ratio: section.settings.image_ratio, style: section.settings.card_style, cta_text: block.settings.cta_text, sizes: '(min-width: 990px) 33vw, 70vw' -%}
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
          <button class="mg-carousel__arrow mg-carousel__arrow--next" type="button" data-mg-carousel-next aria-label="{{ 'general.accessibility.next' | t }}">{%- render 'icon', name: 'chevron-right' -%}</button>
        </mg-carousel>
      {%- else -%}
        <ul class="mg-related__grid" role="list" data-mg-animate>
          {%- for block in section.blocks -%}
            {%- if block.settings.collection != blank -%}
              <li {{ block.shopify_attributes }}>
                {%- render 'collection-card', collection: block.settings.collection, image_override: block.settings.image, heading: block.settings.heading, ratio: section.settings.image_ratio, style: section.settings.card_style, cta_text: block.settings.cta_text, sizes: '(min-width: 990px) 33vw, 100vw' -%}
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    {%- else -%}
      <ul class="mg-related__grid" role="list">
        {%- for i in (1..cols) -%}<li><div class="mg-image-placeholder" style="aspect-ratio: {{ section.settings.image_ratio }};">{{ 'collection-' | append: i | placeholder_svg_tag: 'mg-image-placeholder__svg' }}</div></li>{%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.mg-related { background: var(--mg-related-bg, transparent); color: var(--mg-related-text, var(--mg-text)); padding-block: var(--mg-related-pad-top, var(--mg-section-spacing)) var(--mg-related-pad-bottom, var(--mg-section-spacing)); }
.mg-related__header { text-align: center; }
.mg-related .mg-section-header__title { color: inherit; }
.mg-related__grid { display: grid; grid-template-columns: repeat(var(--mg-cols, 3), minmax(0, 1fr)); gap: var(--mg-space-6); list-style: none; margin: 0; padding: 0; }

[data-mg-animate-section] [data-mg-animate] { opacity: 0; transform: translateY(20px); transition: opacity var(--mg-dur-slow) var(--mg-ease), transform var(--mg-dur-slow) var(--mg-ease); }
[data-mg-animate-section].is-revealed [data-mg-animate] { opacity: 1; transform: none; }

@media (max-width: 989px) { .mg-related__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
@media (max-width: 767px) { .mg-related__grid { grid-template-columns: 1fr; gap: var(--mg-space-4); } }
@media (prefers-reduced-motion: reduce) { [data-mg-animate-section] [data-mg-animate] { opacity: 1 !important; transform: none !important; } }
{% endstyle %}

{% schema %}
{
  "name": "Related collections",
  "tag": "section",
  "class": "mg-related-section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Explore" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "You may also like" },

    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "layout", "label": "Layout", "options": [ { "value": "grid", "label": "Grid" }, { "value": "carousel", "label": "Carousel" } ], "default": "grid" },
    { "type": "range", "id": "columns", "min": 2, "max": 4, "step": 1, "label": "Columns / per view", "default": 3 },
    { "type": "select", "id": "card_style", "label": "Card style", "options": [ { "value": "overlay", "label": "Text over image" }, { "value": "below", "label": "Text below image" } ], "default": "overlay" },
    { "type": "select", "id": "image_ratio", "label": "Image ratio", "options": [ { "value": "3/4", "label": "Portrait (3:4)" }, { "value": "4/5", "label": "Portrait (4:5)" }, { "value": "1/1", "label": "Square" }, { "value": "16/9", "label": "Landscape" } ], "default": "3/4" },

    { "type": "header", "content": "Style" },
    { "type": "color", "id": "background", "label": "Background", "default": "#FBF8F2" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#1C1C1C" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding top", "default": 96 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding bottom", "default": 96 },

    { "type": "header", "content": "Advanced" },
    { "type": "checkbox", "id": "animate", "label": "Animate on scroll", "default": true },
    { "type": "text", "id": "anchor_id", "label": "Section anchor ID" },
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Image override" },
        { "type": "text", "id": "heading", "label": "Title override" },
        { "type": "text", "id": "cta_text", "label": "Call to action", "default": "Shop now" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    { "name": "Related collections", "blocks": [ { "type": "collection" }, { "type": "collection" }, { "type": "collection" } ] }
  ]
}
{% endschema %}
