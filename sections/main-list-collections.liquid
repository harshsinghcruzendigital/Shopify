{%- comment -%} Madrishi Global — All collections listing (Part 9). {%- endcomment -%}
<section class="mg-collist mg-section" id="MainListColl-{{ section.id }}" data-mg-animate-section style="--mg-cols: {{ section.settings.columns }};">
  <div class="mg-collist__inner mg-container">
    <header class="mg-section-header mg-section-header--center" data-mg-animate>
      <p class="mg-eyebrow">{{ section.settings.eyebrow | default: 'Collections' | escape }}</p>
      <h1 class="mg-section-header__title">{{ section.settings.heading | default: 'All Collections' | escape }}</h1>
    </header>
    <ul class="mg-collist__grid" role="list" data-mg-animate>
      {%- for collection in collections -%}
        <li>{%- render 'collection-card', collection: collection, ratio: section.settings.image_ratio, style: section.settings.card_style -%}</li>
      {%- endfor -%}
    </ul>
  </div>
</section>
{% stylesheet %}
.mg-collist__grid { display: grid; grid-template-columns: repeat(var(--mg-cols, 3), minmax(0, 1fr)); gap: var(--mg-space-6); list-style: none; margin: var(--mg-space-9) 0 0; padding: 0; }
[data-mg-animate-section] [data-mg-animate] { opacity: 0; transform: translateY(16px); transition: opacity var(--mg-dur-slow) var(--mg-ease), transform var(--mg-dur-slow) var(--mg-ease); }
[data-mg-animate-section].is-revealed [data-mg-animate] { opacity: 1; transform: none; }
@media (max-width: 989px) { .mg-collist__grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 600px) { .mg-collist__grid { grid-template-columns: 1fr; } }
@media (prefers-reduced-motion: reduce) { [data-mg-animate-section] [data-mg-animate] { opacity: 1 !important; transform: none !important; } }
{% endstyle %}
{% schema %}
{
  "name": "Collections list",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Collections" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "All Collections" },
    { "type": "range", "id": "columns", "min": 2, "max": 4, "step": 1, "label": "Columns", "default": 3 },
    { "type": "select", "id": "card_style", "label": "Card style", "options": [ { "value": "overlay", "label": "Text over image" }, { "value": "below", "label": "Text below" } ], "default": "overlay" },
    { "type": "select", "id": "image_ratio", "label": "Image ratio", "options": [ { "value": "3/4", "label": "3:4" }, { "value": "1/1", "label": "Square" }, { "value": "16/9", "label": "16:9" } ], "default": "3/4" }
  ],
  "enabled_on": { "templates": ["list-collections"] }
}
{% endschema %}
