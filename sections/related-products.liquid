{%- comment -%}
  Madrishi Global — Product Page: Related Products
  Shopify product recommendations, fetched via the Section Rendering
  API into <mg-recommendations>. Reuses product-card + <mg-carousel>.
{%- endcomment -%}
{%- liquid
  assign limit = section.settings.product_limit
  assign rec_url = routes.product_recommendations_url | append: '?section_id=' | append: section.id | append: '&product_id=' | append: product.id | append: '&limit=' | append: limit
-%}
<section
  class="mg-related-products {{ section.settings.custom_class }}"
  id="{{ section.settings.anchor_id | default: section.id }}"
  style="--mg-rp-bg: {{ section.settings.background }}; --mg-rp-pad-top: {{ section.settings.padding_top }}px; --mg-rp-pad-bottom: {{ section.settings.padding_bottom }}px; --mg-carousel-item-d: calc(25% - var(--mg-space-5));"
  data-mg-animate-section
>
  <mg-recommendations
    class="mg-related-products__el"
    data-url="{{ rec_url }}"
    data-performed="{{ recommendations.performed }}"
    {% if recommendations.performed and recommendations.products_count == 0 %}hidden{% endif %}
  >
    <div class="mg-related-products__inner mg-container">
      <div class="mg-section-header mg-section-header--center">
        {%- if section.settings.eyebrow != blank -%}<p class="mg-section-header__eyebrow mg-eyebrow" data-mg-animate>{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="mg-section-header__title" data-mg-animate>{{ section.settings.heading | escape }}</h2>{%- endif -%}
      </div>

      <div data-mg-recommendations-inner>
        {%- if recommendations.performed and recommendations.products_count > 0 -%}
          <mg-carousel class="mg-carousel">
            <button class="mg-carousel__arrow mg-carousel__arrow--prev" type="button" data-mg-carousel-prev aria-label="{{ 'general.accessibility.previous' | t }}">{%- render 'icon', name: 'chevron-left' -%}</button>
            <ul class="mg-carousel__track" data-mg-carousel-track role="list">
              {%- for product in recommendations.products -%}
                <li>{%- render 'product-card', product: product, sizes: '(min-width:990px) 25vw, 60vw' -%}</li>
              {%- endfor -%}
            </ul>
            <button class="mg-carousel__arrow mg-carousel__arrow--next" type="button" data-mg-carousel-next aria-label="{{ 'general.accessibility.next' | t }}">{%- render 'icon', name: 'chevron-right' -%}</button>
          </mg-carousel>
        {%- endif -%}
      </div>
    </div>
  </mg-recommendations>
</section>

{% stylesheet %}
.mg-related-products { background: var(--mg-rp-bg, var(--mg-bg-page)); padding-block: var(--mg-rp-pad-top, var(--mg-section-spacing)) var(--mg-rp-pad-bottom, var(--mg-section-spacing)); }
.mg-related-products__el[hidden] { display: none; }
[data-mg-animate-section] [data-mg-animate] { opacity: 0; transform: translateY(20px); transition: opacity var(--mg-dur-slow) var(--mg-ease), transform var(--mg-dur-slow) var(--mg-ease); }
[data-mg-animate-section].is-revealed [data-mg-animate] { opacity: 1; transform: none; }
@media (prefers-reduced-motion: reduce) { [data-mg-animate-section] [data-mg-animate] { opacity: 1 !important; transform: none !important; } }
{% endstyle %}

{% schema %}
{
  "name": "Related products",
  "tag": "section",
  "class": "mg-related-products-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "You may also like" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Complete the look" },
    { "type": "range", "id": "product_limit", "min": 2, "max": 10, "step": 1, "label": "Products", "default": 8 },
    { "type": "color", "id": "background", "label": "Background", "default": "#FBF8F2" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 200, "step": 8, "unit": "px", "label": "Padding top", "default": 96 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 200, "step": 8, "unit": "px", "label": "Padding bottom", "default": 96 },
    { "type": "text", "id": "anchor_id", "label": "Section anchor ID" },
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" }
  ],
  "enabled_on": { "templates": ["product"] },
  "presets": [ { "name": "Related products" } ]
}
{% endschema %}
