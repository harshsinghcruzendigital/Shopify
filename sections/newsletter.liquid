{%- comment -%}
  Madrishi Global — Homepage Section 17: Newsletter
  Luxury signup band with optional background image/overlay, native
  customer form, success + error states. No section JS.
{%- endcomment -%}
<section
  class="mg-news mg-news--{{ section.settings.layout }} {{ section.settings.custom_class }}"
  id="{{ section.settings.anchor_id | default: section.id }}"
  style="--mg-news-bg: {{ section.settings.background }}; --mg-news-text: {{ section.settings.text_color }}; --mg-news-pad: {{ section.settings.padding }}px;"
  data-mg-animate-section
>
  {%- if section.settings.image != blank -%}
    <div class="mg-news__media">
      {%- render 'responsive-image', image: section.settings.image, sizes: '100vw', class: 'mg-news__img' -%}
      {%- if section.settings.overlay_opacity > 0 -%}<span class="mg-news__overlay" style="background: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};" aria-hidden="true"></span>{%- endif -%}
    </div>
  {%- endif -%}

  <div class="mg-news__inner mg-container mg-container--narrow">
    <div class="mg-news__content" data-mg-animate>
      {%- if section.settings.eyebrow != blank -%}<p class="mg-eyebrow">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="mg-news__heading">{{ section.settings.heading | escape }}</h2>{%- endif -%}
      {%- if section.settings.text != blank -%}<div class="mg-news__text rte">{{ section.settings.text }}</div>{%- endif -%}

      {%- form 'customer', class: 'mg-news__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        {%- if form.posted_successfully? -%}
          <p class="mg-news__success">{{ 'newsletter.success' | t }}</p>
        {%- else -%}
          <div class="mg-news__field">
            <label class="visually-hidden" for="mg-news-email">{{ 'newsletter.email' | t }}</label>
            <input id="mg-news-email" type="email" name="contact[email]" placeholder="{{ 'newsletter.placeholder' | t }}" required autocomplete="email">
            <button type="submit" class="mg-btn mg-btn--primary">{{ section.settings.button_text | default: 'Subscribe' | escape }}</button>
          </div>
          {%- if form.errors -%}<p class="mg-news__error">{{ form.errors.translated_fields.email }} {{ form.errors.messages.email }}</p>{%- endif -%}
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</section>

{% stylesheet %}
.mg-news { position: relative; background: var(--mg-news-bg, var(--mg-navy)); color: var(--mg-news-text, var(--mg-ivory)); }
.mg-news__media { position: absolute; inset: 0; z-index: 0; }
.mg-news__media .mg-picture, .mg-news__img { width: 100%; height: 100%; object-fit: cover; }
.mg-news__overlay { position: absolute; inset: 0; }
.mg-news__inner { position: relative; z-index: 1; padding-block: var(--mg-news-pad, 120px); }
.mg-news__content { text-align: center; max-width: 620px; margin-inline: auto; }
.mg-news__heading { font-size: var(--mg-fs-section); font-weight: 300; line-height: var(--mg-lh-heading); color: inherit; margin-bottom: var(--mg-space-4); }
.mg-news__text { color: inherit; opacity: 0.9; margin-bottom: var(--mg-space-6); }
.mg-news__field { display: flex; gap: var(--mg-space-2); max-width: 480px; margin-inline: auto; }
.mg-news__field input { flex: 1; height: 52px; padding: 0 var(--mg-space-4); border: var(--mg-border-hairline) solid rgba(255,255,255,0.4); background: rgba(255,255,255,0.06); color: inherit; }
.mg-news__field input::placeholder { color: currentColor; opacity: 0.7; }
.mg-news--light .mg-news__field input { border-color: var(--mg-border-input); background: var(--mg-white); color: var(--mg-text); }
.mg-news__success { color: var(--mg-gold); }
.mg-news__error { color: #E2A6A0; font-size: var(--mg-fs-caption); margin-top: var(--mg-space-2); }
[data-mg-animate-section] [data-mg-animate] { opacity: 0; transform: translateY(20px); transition: opacity var(--mg-dur-slow) var(--mg-ease), transform var(--mg-dur-slow) var(--mg-ease); }
[data-mg-animate-section].is-revealed [data-mg-animate] { opacity: 1; transform: none; }
@media (prefers-reduced-motion: reduce) { [data-mg-animate-section] [data-mg-animate] { opacity: 1 !important; transform: none !important; } }
{% endstyle %}

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "mg-news-section",
  "settings": [
    { "type": "select", "id": "layout", "label": "Style", "options": [ { "value": "dark", "label": "Dark / image" }, { "value": "light", "label": "Light" } ], "default": "dark" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Stay Connected" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join the House of Madrishi" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>First access to new collections, private events and editorial stories.</p>" },
    { "type": "text", "id": "button_text", "label": "Button label", "default": "Subscribe" },
    { "type": "header", "content": "Background" },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#11182B" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 90, "step": 5, "unit": "%", "label": "Overlay opacity", "default": 55 },
    { "type": "header", "content": "Style" },
    { "type": "color", "id": "background", "label": "Background color", "default": "#1B2A4A" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#F7F4EC" },
    { "type": "range", "id": "padding", "min": 48, "max": 200, "step": 8, "unit": "px", "label": "Vertical padding", "default": 120 },
    { "type": "text", "id": "anchor_id", "label": "Section anchor ID" },
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" }
  ],
  "presets": [ { "name": "Newsletter" } ]
}
{% endschema %}
