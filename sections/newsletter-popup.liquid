{%- comment -%}
  ============================================================
  Madrishi Global — Newsletter Popup (Component 9)
  Modal with delay/exit-intent triggers, image, copy, native email
  form, success state, and dismissal memory (localStorage).
  Custom element: <mg-popup>
  ============================================================
{%- endcomment -%}
{%- if section.settings.enable -%}
  <mg-popup
    class="mg-popup"
    id="mg-newsletter-popup"
    hidden
    data-delay="{{ section.settings.delay | times: 1000 }}"
    {% if section.settings.exit_intent %}data-exit-intent="true"{% endif %}
    data-remember-days="{{ section.settings.remember_days }}"
    {% if form.posted_successfully? %}data-force-open="true"{% endif %}
  >
    <div class="mg-popup__overlay" data-mg-popup-close></div>
    <div class="mg-popup__dialog" role="dialog" aria-modal="true" aria-labelledby="mg-popup-title">
      <button class="mg-popup__close" type="button" data-mg-popup-close aria-label="{{ 'general.accessibility.close' | t }}">{%- render 'icon', name: 'close' -%}</button>
      <div class="mg-popup__grid">
        {%- if section.settings.image != blank -%}
          <div class="mg-popup__media">
            {%- render 'responsive-image', image: section.settings.image, sizes: '(min-width:768px) 320px, 100vw', class: 'mg-popup__img', aspect_ratio: '1/1' -%}
          </div>
        {%- endif -%}
        <div class="mg-popup__content">
          {%- if section.settings.eyebrow != blank -%}<p class="mg-eyebrow">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
          <h2 class="mg-popup__title" id="mg-popup-title">{{ section.settings.heading | escape }}</h2>
          {%- if section.settings.text != blank -%}<div class="mg-popup__text rte">{{ section.settings.text }}</div>{%- endif -%}
          {%- form 'customer', class: 'mg-popup__form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter,popup">
            {%- if form.posted_successfully? -%}
              <p class="mg-popup__success">{{ 'newsletter.success' | t | default: 'Thank you for subscribing.' }}</p>
            {%- else -%}
              <div class="mg-popup__field">
                <label class="visually-hidden" for="mg-popup-email">{{ 'newsletter.email' | t }}</label>
                <input id="mg-popup-email" type="email" name="contact[email]" placeholder="{{ 'newsletter.placeholder' | t }}" required autocomplete="email">
                <button type="submit" class="mg-btn mg-btn--primary">{{ section.settings.button_text | default: 'Subscribe' | escape }}</button>
              </div>
              {%- if form.errors -%}<p class="mg-popup__error">{{ form.errors.translated_fields.email }} {{ form.errors.messages.email }}</p>{%- endif -%}
            {%- endif -%}
          {%- endform -%}
          {%- if section.settings.disclaimer != blank -%}<p class="mg-popup__disclaimer">{{ section.settings.disclaimer | escape }}</p>{%- endif -%}
        </div>
      </div>
    </div>
  </mg-popup>
{%- endif -%}

{% stylesheet %}
.mg-popup { position: fixed; inset: 0; z-index: var(--mg-z-modal); }
.mg-popup[hidden] { display: none; }
.mg-popup__overlay { position: absolute; inset: 0; background: var(--mg-overlay-strong); opacity: 0; transition: opacity var(--mg-dur-base) var(--mg-ease); }
.mg-popup.is-open .mg-popup__overlay { opacity: 1; }
.mg-popup__dialog { position: absolute; top: 50%; left: 50%; width: min(720px, 92vw); max-height: 90vh; overflow-y: auto; background: var(--mg-bg-card); box-shadow: var(--mg-shadow-lg); transform: translate(-50%, -48%); opacity: 0; transition: opacity var(--mg-dur-base) var(--mg-ease), transform var(--mg-dur-base) var(--mg-ease); }
.mg-popup.is-open .mg-popup__dialog { opacity: 1; transform: translate(-50%, -50%); }
.mg-popup__close { position: absolute; top: var(--mg-space-3); right: var(--mg-space-3); z-index: 1; width: 40px; height: 40px; display: inline-flex; align-items: center; justify-content: center; color: var(--mg-navy); }
.mg-popup__grid { display: grid; grid-template-columns: 1fr 1fr; }
.mg-popup__media .mg-popup__img { width: 100%; height: 100%; object-fit: cover; }
.mg-popup__content { padding: var(--mg-space-9); display: flex; flex-direction: column; justify-content: center; gap: var(--mg-space-3); }
.mg-popup__title { font-size: var(--mg-fs-section); font-weight: 300; line-height: var(--mg-lh-heading); }
.mg-popup__text { color: var(--mg-text-secondary); }
.mg-popup__field { display: flex; gap: var(--mg-space-2); margin-top: var(--mg-space-3); }
.mg-popup__field input { flex: 1; height: 52px; padding: 0 var(--mg-space-4); border: var(--mg-border-hairline) solid var(--mg-border-input); }
.mg-popup__success { color: var(--mg-success); }
.mg-popup__error { color: var(--mg-error); font-size: var(--mg-fs-caption); }
.mg-popup__disclaimer { font-size: var(--mg-fs-caption); color: var(--mg-text-muted); margin-top: var(--mg-space-2); }
@media (max-width: 767px) { .mg-popup__grid { grid-template-columns: 1fr; } .mg-popup__media { display: none; } .mg-popup__content { padding: var(--mg-space-7); } }
@media (prefers-reduced-motion: reduce) { .mg-popup__overlay, .mg-popup__dialog { transition: none; } }
{% endstyle %}

{% javascript %}
class MGPopup extends HTMLElement {
  connectedCallback() {
    this.dialog = this.querySelector('.mg-popup__dialog');
    this.key = 'mg-popup-dismissed';
    this.trap = window.MG ? new MG.FocusTrap(this.dialog) : null;

    this.addEventListener('click', (e) => { if (e.target.closest('[data-mg-popup-close]')) this.close(); });
    this.addEventListener('keydown', (e) => { if (e.key === 'Escape') this.close(); });

    if (this.dataset.forceOpen === 'true') { this.open(); return; }
    if (this._dismissed() || (window.Shopify && Shopify.designMode)) {
      if (window.Shopify && Shopify.designMode) {/* allow editor preview via select */}
      else return;
    }
    const delay = parseInt(this.dataset.delay, 10) || 5000;
    this._timer = setTimeout(() => this.open(), delay);
    if (this.dataset.exitIntent === 'true') {
      this._exit = (e) => { if (e.clientY <= 0) this.open(); };
      document.addEventListener('mouseout', this._exit);
    }
  }
  disconnectedCallback() { clearTimeout(this._timer); if (this._exit) document.removeEventListener('mouseout', this._exit); }

  open() {
    if (this.classList.contains('is-open')) return;
    clearTimeout(this._timer);
    if (this._exit) document.removeEventListener('mouseout', this._exit);
    this.hidden = false;
    requestAnimationFrame(() => this.classList.add('is-open'));
    document.body.style.overflow = 'hidden';
    if (this.trap) this.trap.activate();
  }
  close() {
    this.classList.remove('is-open');
    document.body.style.overflow = '';
    if (this.trap) this.trap.deactivate();
    this._remember();
    setTimeout(() => { this.hidden = true; }, 320);
  }
  _remember() {
    const days = parseInt(this.dataset.rememberDays, 10) || 14;
    try { localStorage.setItem(this.key, String(Date.now() + days * 86400000)); } catch (e) {}
  }
  _dismissed() {
    try { const until = parseInt(localStorage.getItem(this.key), 10); return until && Date.now() < until; } catch (e) { return false; }
  }
}
if (!customElements.get('mg-popup')) customElements.define('mg-popup', MGPopup);
{% endjavascript %}

{% schema %}
{
  "name": "Newsletter popup",
  "settings": [
    { "type": "checkbox", "id": "enable", "label": "Enable popup", "default": false },
    { "type": "range", "id": "delay", "min": 0, "max": 30, "step": 1, "unit": "s", "label": "Show after delay", "default": 6 },
    { "type": "checkbox", "id": "exit_intent", "label": "Also trigger on exit intent", "default": true },
    { "type": "range", "id": "remember_days", "min": 1, "max": 90, "step": 1, "unit": "d", "label": "Hide for (days) after dismiss", "default": 14 },
    { "type": "header", "content": "Content" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Madrishi Global" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join the House" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Enjoy 10% on your first order and first access to new collections.</p>" },
    { "type": "text", "id": "button_text", "label": "Button label", "default": "Subscribe" },
    { "type": "text", "id": "disclaimer", "label": "Disclaimer", "default": "By subscribing you agree to our Privacy Policy." }
  ]
}
{% endschema %}
