{%- comment -%}
  Madrishi Global — Homepage Section 15: Journal
  Editorial blog cards from a chosen blog. Reuses article-card. No JS.
{%- endcomment -%}
{%- liquid
  assign blog = blogs[section.settings.blog]
  assign limit = section.settings.post_limit
-%}
<section
  class="mg-journal {{ section.settings.custom_class }}"
  id="{{ section.settings.anchor_id | default: section.id }}"
  style="--mg-journal-bg: {{ section.settings.background }}; --mg-journal-text: {{ section.settings.text_color }}; --mg-journal-pad-top: {{ section.settings.padding_top }}px; --mg-journal-pad-bottom: {{ section.settings.padding_bottom }}px; --mg-cols: {{ section.settings.columns }};"
  data-mg-animate-section
>
  <div class="mg-journal__inner mg-container">
    <div class="mg-journal__header mg-section-header {% if section.settings.heading_alignment == 'center' %}mg-section-header--center{% endif %}">
      <div>
        {%- if section.settings.eyebrow != blank -%}<p class="mg-section-header__eyebrow mg-eyebrow" data-mg-animate>{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="mg-section-header__title" data-mg-animate>{{ section.settings.heading | escape }}</h2>{%- endif -%}
      </div>
      {%- if section.settings.show_view_all and blog != blank -%}
        <a class="mg-btn mg-btn--text" href="{{ blog.url }}" data-mg-animate>{{ section.settings.view_all_text | default: 'View all' | escape }}</a>
      {%- endif -%}
    </div>

    <div class="mg-journal__grid" data-mg-animate>
      {%- if blog != blank and blog.articles_count > 0 -%}
        {%- for article in blog.articles limit: limit -%}
          {%- render 'article-card', article: article, ratio: section.settings.image_ratio -%}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..section.settings.columns) -%}
          <article class="mg-article-card"><div class="mg-image-placeholder" style="aspect-ratio: 16/9;">{{ 'image' | placeholder_svg_tag }}</div><div class="mg-article-card__body"><h3 class="mg-article-card__title">Journal entry</h3></div></article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
.mg-journal { background: var(--mg-journal-bg, var(--mg-bg-page)); color: var(--mg-journal-text, var(--mg-text)); padding-block: var(--mg-journal-pad-top, var(--mg-section-spacing)) var(--mg-journal-pad-bottom, var(--mg-section-spacing)); }
.mg-journal__header { display: flex; align-items: flex-end; justify-content: space-between; gap: var(--mg-space-5); flex-wrap: wrap; }
.mg-journal .mg-section-header__title { color: inherit; }
.mg-journal__grid { display: grid; grid-template-columns: repeat(var(--mg-cols, 3), minmax(0, 1fr)); gap: var(--mg-space-8); }
[data-mg-animate-section] [data-mg-animate] { opacity: 0; transform: translateY(20px); transition: opacity var(--mg-dur-slow) var(--mg-ease), transform var(--mg-dur-slow) var(--mg-ease); }
[data-mg-animate-section].is-revealed [data-mg-animate] { opacity: 1; transform: none; }
@media (max-width: 989px) { .mg-journal__grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 600px) { .mg-journal__grid { grid-template-columns: 1fr; } }
@media (prefers-reduced-motion: reduce) { [data-mg-animate-section] [data-mg-animate] { opacity: 1 !important; transform: none !important; } }
{% endstyle %}

{% schema %}
{
  "name": "Journal",
  "tag": "section",
  "class": "mg-journal-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Journal" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Stories & Inspiration" },
    { "type": "blog", "id": "blog", "label": "Blog" },
    { "type": "range", "id": "post_limit", "min": 2, "max": 6, "step": 1, "label": "Posts to show", "default": 3 },
    { "type": "range", "id": "columns", "min": 2, "max": 4, "step": 1, "label": "Columns", "default": 3 },
    { "type": "select", "id": "image_ratio", "label": "Image ratio", "options": [ { "value": "16/9", "label": "Landscape (16:9)" }, { "value": "4/3", "label": "4:3" }, { "value": "3/2", "label": "3:2" } ], "default": "16/9" },
    { "type": "select", "id": "heading_alignment", "label": "Heading alignment", "options": [ { "value": "left", "label": "Left (with view-all)" }, { "value": "center", "label": "Center" } ], "default": "left" },
    { "type": "checkbox", "id": "show_view_all", "label": "Show view-all link", "default": true },
    { "type": "text", "id": "view_all_text", "label": "View-all label", "default": "View all" },
    { "type": "color", "id": "background", "label": "Background", "default": "#FBF8F2" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#1C1C1C" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 200, "step": 8, "unit": "px", "label": "Padding top", "default": 120 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 200, "step": 8, "unit": "px", "label": "Padding bottom", "default": 120 },
    { "type": "text", "id": "anchor_id", "label": "Section anchor ID" },
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" }
  ],
  "presets": [ { "name": "Journal" } ]
}
{% endschema %}
