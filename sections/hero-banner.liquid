{%- comment -%}
  ============================================================
  Madrishi Global — Section 01: Luxury Hero Banner
  Full-screen editorial hero. Multiple slides (blocks), image or
  background video, art-directed mobile image, overlay, eyebrow +
  heading + subheading + 2 CTAs, scroll indicator, parallax,
  fade/slide transitions, text animation. Fully data-driven.
  Custom element: <mg-hero>
  ============================================================
{%- endcomment -%}

{%- liquid
  assign slides = section.blocks
  assign multi = false
  if slides.size > 1
    assign multi = true
  endif
  case section.settings.height
    when 'full'
      assign height_css = '100svh'
    when 'large'
      assign height_css = '80svh'
    when 'medium'
      assign height_css = '60svh'
    else
      assign height_css = section.settings.custom_height | append: 'px'
  endcase
-%}

<mg-hero
  class="mg-hero {{ section.settings.custom_class }}"
  id="{{ section.settings.anchor_id | default: section.id }}"
  data-transition="{{ section.settings.transition }}"
  {% if multi and section.settings.autoplay %}data-autoplay="true" data-speed="{{ section.settings.autoplay_speed | times: 1000 }}"{% endif %}
  {% if section.settings.parallax %}data-parallax="true"{% endif %}
  {% if section.settings.text_animation %}data-animate="true"{% endif %}
  style="--mg-hero-height: {{ height_css }};"
  role="region"
  aria-roledescription="carousel"
  aria-label="{{ section.settings.aria_label | default: 'Hero' | escape }}"
>
  <div class="mg-hero__track" data-mg-track>
    {%- for block in slides -%}
      {%- liquid
        assign content_align = block.settings.content_alignment
        assign img_loading = 'lazy'
        assign img_fetch = ''
        if forloop.first
          assign img_loading = 'eager'
          assign img_fetch = 'high'
        endif
      -%}
      <div
        class="mg-hero__slide {% if forloop.first %}is-active{% endif %} mg-hero__slide--{{ content_align }}"
        data-mg-slide
        data-index="{{ forloop.index0 }}"
        {{ block.shopify_attributes }}
        {% unless forloop.first %}aria-hidden="true"{% endunless %}
        role="group"
        aria-roledescription="slide"
        aria-label="{{ forloop.index }} / {{ slides.size }}"
      >
        {%- comment -%} Media {%- endcomment -%}
        <div class="mg-hero__media" data-mg-parallax-target>
          {%- if block.settings.video != blank -%}
            {{ block.settings.video | video_tag: image_size: '1100x', loop: true, autoplay: true, muted: true, controls: false, class: 'mg-hero__video' }}
          {%- elsif block.settings.image != blank -%}
            {%- render 'responsive-image',
              image: block.settings.image,
              mobile: block.settings.image_mobile,
              sizes: '100vw',
              class: 'mg-hero__img',
              loading: img_loading,
              fetchpriority: img_fetch
            -%}
          {%- else -%}
            <div class="mg-hero__placeholder">{{ 'lifestyle-1' | placeholder_svg_tag: 'mg-hero__placeholder-svg' }}</div>
          {%- endif -%}

          {%- if block.settings.overlay_opacity > 0 -%}
            <span class="mg-hero__overlay" style="background: {{ block.settings.overlay_color }}; opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};" aria-hidden="true"></span>
          {%- endif -%}
        </div>

        {%- comment -%} Content {%- endcomment -%}
        <div class="mg-hero__content-wrap mg-container">
          <div class="mg-hero__content" style="--mg-hero-text: {{ block.settings.text_color }}; max-width: {{ block.settings.content_width }}px;">
            {%- if block.settings.eyebrow != blank -%}
              <p class="mg-hero__eyebrow mg-eyebrow" data-mg-animate>{{ block.settings.eyebrow | escape }}</p>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h2 class="mg-hero__heading" data-mg-animate>{{ block.settings.heading | escape }}</h2>
            {%- endif -%}
            {%- if block.settings.subheading != blank -%}
              <div class="mg-hero__subheading" data-mg-animate>{{ block.settings.subheading }}</div>
            {%- endif -%}
            {%- if block.settings.button_1_text != blank or block.settings.button_2_text != blank -%}
              <div class="mg-hero__actions" data-mg-animate>
                {%- if block.settings.button_1_text != blank -%}
                  <a class="mg-btn mg-btn--{{ block.settings.button_1_style }}" href="{{ block.settings.button_1_link | default: '#' }}">{{ block.settings.button_1_text | escape }}</a>
                {%- endif -%}
                {%- if block.settings.button_2_text != blank -%}
                  <a class="mg-btn mg-btn--{{ block.settings.button_2_style }}" href="{{ block.settings.button_2_link | default: '#' }}">{{ block.settings.button_2_text | escape }}</a>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- else -%}
      <div class="mg-hero__slide is-active mg-hero__slide--center">
        <div class="mg-hero__media"><div class="mg-hero__placeholder">{{ 'lifestyle-1' | placeholder_svg_tag }}</div></div>
        <div class="mg-hero__content-wrap mg-container">
          <div class="mg-hero__content"><h2 class="mg-hero__heading">Add a hero slide</h2></div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if multi -%}
    <div class="mg-hero__controls mg-container">
      <button class="mg-hero__arrow mg-hero__arrow--prev" type="button" aria-label="{{ 'general.accessibility.previous' | t }}" data-mg-prev>{%- render 'icon', name: 'chevron-left' -%}</button>
      <button class="mg-hero__arrow mg-hero__arrow--next" type="button" aria-label="{{ 'general.accessibility.next' | t }}" data-mg-next>{%- render 'icon', name: 'chevron-right' -%}</button>
    </div>
    {%- if section.settings.show_dots -%}
      <div class="mg-hero__dots" role="tablist" aria-label="Hero slides">
        {%- for block in slides -%}
          <button class="mg-hero__dot {% if forloop.first %}is-active{% endif %}" type="button" role="tab" aria-selected="{% if forloop.first %}true{% else %}false{% endif %}" aria-label="{{ forloop.index }}" data-mg-dot data-index="{{ forloop.index0 }}"></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- endif -%}

  {%- if section.settings.show_scroll_indicator -%}
    <button class="mg-hero__scroll" type="button" aria-label="Scroll down" data-mg-scroll>
      <span class="mg-hero__scroll-line" aria-hidden="true"></span>
    </button>
  {%- endif -%}
</mg-hero>

{% stylesheet %}
.mg-hero {
  position: relative;
  display: block;
  height: var(--mg-hero-height, 100svh);
  min-height: 480px;
  overflow: hidden;
  background: var(--mg-navy-deep);
}
.mg-hero__track, .mg-hero__slide { position: absolute; inset: 0; }
.mg-hero__slide {
  display: flex;
  opacity: 0;
  visibility: hidden;
  transition: opacity var(--mg-dur-slow) var(--mg-ease), visibility var(--mg-dur-slow);
}
.mg-hero__slide.is-active { opacity: 1; visibility: visible; }
.mg-hero[data-transition="slide"] .mg-hero__slide { transition: transform var(--mg-dur-slow) var(--mg-ease), opacity var(--mg-dur-slow) var(--mg-ease); }

.mg-hero__media { position: absolute; inset: 0; z-index: 0; }
.mg-hero__media .mg-picture,
.mg-hero__img, .mg-hero__video, .mg-hero__placeholder {
  width: 100%; height: 100%;
}
.mg-hero__img, .mg-hero__video { object-fit: cover; }
.mg-hero[data-parallax="true"] .mg-hero__media { will-change: transform; height: 120%; top: -10%; }
.mg-hero__overlay { position: absolute; inset: 0; }

.mg-hero__content-wrap {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  width: 100%;
}
.mg-hero__slide--left .mg-hero__content-wrap { justify-content: flex-start; text-align: left; }
.mg-hero__slide--center .mg-hero__content-wrap { justify-content: center; text-align: center; }
.mg-hero__slide--right .mg-hero__content-wrap { justify-content: flex-end; text-align: right; }
.mg-hero__content { color: var(--mg-hero-text, var(--mg-ivory)); }
.mg-hero__eyebrow { color: inherit; opacity: 0.9; margin-bottom: var(--mg-space-4); }
.mg-hero__heading {
  font-size: var(--mg-fs-display);
  font-weight: 300;
  line-height: var(--mg-lh-tight);
  color: inherit;
  margin-bottom: var(--mg-space-5);
}
.mg-hero__subheading {
  font-size: var(--mg-fs-body-lg);
  line-height: var(--mg-lh-body);
  color: inherit;
  margin-bottom: var(--mg-space-7);
  max-width: 52ch;
}
.mg-hero__slide--center .mg-hero__subheading { margin-inline: auto; }
.mg-hero__slide--right .mg-hero__subheading { margin-left: auto; }
.mg-hero__actions { display: flex; flex-wrap: wrap; gap: var(--mg-space-4); }
.mg-hero__slide--center .mg-hero__actions { justify-content: center; }
.mg-hero__slide--right .mg-hero__actions { justify-content: flex-end; }

/* Text animation on active slide */
.mg-hero[data-animate="true"] [data-mg-animate] { opacity: 0; transform: translateY(24px); }
.mg-hero[data-animate="true"] .mg-hero__slide.is-active [data-mg-animate] {
  opacity: 1; transform: translateY(0);
  transition: opacity var(--mg-dur-slow) var(--mg-ease), transform var(--mg-dur-slow) var(--mg-ease);
}
.mg-hero[data-animate="true"] .mg-hero__slide.is-active .mg-hero__heading { transition-delay: 120ms; }
.mg-hero[data-animate="true"] .mg-hero__slide.is-active .mg-hero__subheading { transition-delay: 220ms; }
.mg-hero[data-animate="true"] .mg-hero__slide.is-active .mg-hero__actions { transition-delay: 320ms; }

/* Controls */
.mg-hero__controls {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: space-between;
  z-index: 2; pointer-events: none;
}
.mg-hero__arrow {
  pointer-events: auto;
  display: inline-flex; align-items: center; justify-content: center;
  width: 48px; height: 48px;
  color: var(--mg-ivory);
  background: rgba(17,24,43,0.25);
  border-radius: var(--mg-radius-pill);
  opacity: var(--mg-opacity-muted);
  transition: opacity var(--mg-dur-base) var(--mg-ease), background var(--mg-dur-base) var(--mg-ease);
}
.mg-hero__arrow:hover { opacity: 1; background: rgba(17,24,43,0.45); color: var(--mg-ivory); }

.mg-hero__dots {
  position: absolute; left: 0; right: 0; bottom: var(--mg-space-7);
  display: flex; justify-content: center; gap: var(--mg-space-2);
  z-index: 2;
}
.mg-hero__dot { width: 8px; height: 8px; border-radius: var(--mg-radius-pill); background: var(--mg-ivory); opacity: 0.4; transition: opacity var(--mg-dur-base) var(--mg-ease), width var(--mg-dur-base) var(--mg-ease); }
.mg-hero__dot.is-active { opacity: 1; width: 28px; border-radius: var(--mg-radius-pill); }

.mg-hero__scroll {
  position: absolute; left: 50%; bottom: var(--mg-space-6);
  transform: translateX(-50%);
  z-index: 2;
  width: 24px; height: 48px;
  display: flex; justify-content: center;
}
.mg-hero__scroll-line { width: 1px; height: 100%; background: var(--mg-ivory); transform-origin: top; animation: mg-hero-scroll 2s var(--mg-ease) infinite; }
@keyframes mg-hero-scroll { 0% { transform: scaleY(0); transform-origin: top; } 40% { transform: scaleY(1); transform-origin: top; } 60% { transform: scaleY(1); transform-origin: bottom; } 100% { transform: scaleY(0); transform-origin: bottom; } }

@media (max-width: 767px) {
  .mg-hero__heading { font-size: var(--mg-fs-hero); }
  .mg-hero__arrow { width: 40px; height: 40px; }
  .mg-hero__controls { display: none; }
}
@media (prefers-reduced-motion: reduce) {
  .mg-hero__scroll-line { animation: none; }
  .mg-hero[data-parallax="true"] .mg-hero__media { height: 100%; top: 0; }
}
{% endstyle %}

{% javascript %}
class MGHero extends HTMLElement {
  connectedCallback() {
    this.slides = Array.from(this.querySelectorAll('[data-mg-slide]'));
    this.dots = Array.from(this.querySelectorAll('[data-mg-dot]'));
    this.index = 0;
    this.timer = null;
    const reduced = window.MG && MG.utils.prefersReducedMotion();

    this.querySelector('[data-mg-prev]')?.addEventListener('click', () => this.go(this.index - 1, true));
    this.querySelector('[data-mg-next]')?.addEventListener('click', () => this.go(this.index + 1, true));
    this.dots.forEach((d) => d.addEventListener('click', () => this.go(parseInt(d.dataset.index, 10), true)));
    this.querySelector('[data-mg-scroll]')?.addEventListener('click', () => {
      const target = this.nextElementSibling || this.parentElement?.nextElementSibling;
      (target || this).scrollIntoView({ behavior: reduced ? 'auto' : 'smooth', block: 'start' });
    });

    if (this.dataset.autoplay === 'true' && this.slides.length > 1 && !reduced) {
      this.speed = parseInt(this.dataset.speed, 10) || 6000;
      this.start();
      this.addEventListener('mouseenter', () => this.stop());
      this.addEventListener('mouseleave', () => this.start());
      this.addEventListener('focusin', () => this.stop());
      this.addEventListener('focusout', () => this.start());
    }

    if (this.dataset.parallax === 'true' && !reduced) {
      this.parallaxTargets = Array.from(this.querySelectorAll('[data-mg-parallax-target]'));
      this._onScroll = this._onScroll.bind(this);
      window.addEventListener('scroll', this._onScroll, { passive: true });
    }

    // Keyboard arrows when focused
    this.addEventListener('keydown', (e) => {
      if (this.slides.length < 2) return;
      if (e.key === 'ArrowLeft') this.go(this.index - 1, true);
      if (e.key === 'ArrowRight') this.go(this.index + 1, true);
    });
  }

  disconnectedCallback() {
    this.stop();
    if (this._onScroll) window.removeEventListener('scroll', this._onScroll);
  }

  go(i, user) {
    const n = this.slides.length;
    if (!n) return;
    this.index = (i + n) % n;
    this.slides.forEach((s, idx) => {
      const active = idx === this.index;
      s.classList.toggle('is-active', active);
      s.setAttribute('aria-hidden', active ? 'false' : 'true');
    });
    this.dots.forEach((d, idx) => {
      const active = idx === this.index;
      d.classList.toggle('is-active', active);
      d.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    if (user && this.timer) { this.stop(); this.start(); }
  }

  start() { if (this.slides.length > 1) { this.stop(); this.timer = setInterval(() => this.go(this.index + 1), this.speed); } }
  stop() { if (this.timer) { clearInterval(this.timer); this.timer = null; } }

  _onScroll() {
    const rect = this.getBoundingClientRect();
    if (rect.bottom < 0 || rect.top > window.innerHeight) return;
    const offset = rect.top * -0.15;
    const active = this.slides[this.index]?.querySelector('[data-mg-parallax-target]');
    if (active) active.style.transform = `translate3d(0, ${offset}px, 0)`;
  }
}
if (!customElements.get('mg-hero')) customElements.define('mg-hero', MGHero);
{% endjavascript %}

{% schema %}
{
  "name": "Hero banner",
  "tag": "section",
  "class": "mg-hero-section",
  "settings": [
    { "type": "header", "content": "Size" },
    {
      "type": "select", "id": "height", "label": "Height",
      "options": [
        { "value": "full", "label": "Full screen" },
        { "value": "large", "label": "Large (80%)" },
        { "value": "medium", "label": "Medium (60%)" },
        { "value": "custom", "label": "Custom" }
      ], "default": "full"
    },
    { "type": "range", "id": "custom_height", "min": 400, "max": 1000, "step": 20, "unit": "px", "label": "Custom height", "default": 700 },

    { "type": "header", "content": "Slider" },
    { "type": "select", "id": "transition", "label": "Transition", "options": [ { "value": "fade", "label": "Fade" }, { "value": "slide", "label": "Slide" } ], "default": "fade" },
    { "type": "checkbox", "id": "autoplay", "label": "Auto-play slides", "default": true },
    { "type": "range", "id": "autoplay_speed", "min": 4, "max": 12, "step": 1, "unit": "s", "label": "Slide duration", "default": 6 },
    { "type": "checkbox", "id": "show_dots", "label": "Show dots", "default": true },

    { "type": "header", "content": "Effects" },
    { "type": "checkbox", "id": "parallax", "label": "Parallax on scroll", "default": true },
    { "type": "checkbox", "id": "text_animation", "label": "Animate text", "default": true },
    { "type": "checkbox", "id": "show_scroll_indicator", "label": "Show scroll indicator", "default": true },

    { "type": "header", "content": "Advanced" },
    { "type": "text", "id": "aria_label", "label": "Accessible label", "default": "Hero" },
    { "type": "text", "id": "anchor_id", "label": "Section anchor ID" },
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "header", "content": "Media" },
        { "type": "image_picker", "id": "image", "label": "Desktop image" },
        { "type": "image_picker", "id": "image_mobile", "label": "Mobile image" },
        { "type": "video", "id": "video", "label": "Background video", "info": "Overrides image when set" },
        { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#11182B" },
        { "type": "range", "id": "overlay_opacity", "min": 0, "max": 80, "step": 5, "unit": "%", "label": "Overlay opacity", "default": 30 },

        { "type": "header", "content": "Content" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Timeless Luxury, Globally Crafted" },
        { "type": "richtext", "id": "subheading", "label": "Subheading", "default": "<p>Discover pieces created for those who value heritage and craftsmanship.</p>" },
        {
          "type": "select", "id": "content_alignment", "label": "Alignment",
          "options": [ { "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" } ],
          "default": "center"
        },
        { "type": "range", "id": "content_width", "min": 400, "max": 900, "step": 20, "unit": "px", "label": "Content width", "default": 680 },
        { "type": "color", "id": "text_color", "label": "Text color", "default": "#F7F4EC" },

        { "type": "header", "content": "Button 1" },
        { "type": "text", "id": "button_1_text", "label": "Label", "default": "Discover" },
        { "type": "url", "id": "button_1_link", "label": "Link" },
        { "type": "select", "id": "button_1_style", "label": "Style", "options": [ { "value": "primary", "label": "Primary" }, { "value": "secondary", "label": "Secondary" }, { "value": "outline", "label": "Outline" }, { "value": "ghost", "label": "Ghost" } ], "default": "primary" },

        { "type": "header", "content": "Button 2" },
        { "type": "text", "id": "button_2_text", "label": "Label" },
        { "type": "url", "id": "button_2_link", "label": "Link" },
        { "type": "select", "id": "button_2_style", "label": "Style", "options": [ { "value": "primary", "label": "Primary" }, { "value": "secondary", "label": "Secondary" }, { "value": "outline", "label": "Outline" }, { "value": "ghost", "label": "Ghost" } ], "default": "outline" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Hero banner",
      "blocks": [ { "type": "slide" } ]
    }
  ]
}
{% endschema %}
