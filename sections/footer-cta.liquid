{%- comment -%}
  Madrishi Global — Homepage Section 20: Footer CTA
  Premium closing band: centered statement + CTA, optional background
  image with overlay. The page's final, decisive moment. No section JS.
{%- endcomment -%}
<section
  class="mg-fcta {{ section.settings.custom_class }}"
  id="{{ section.settings.anchor_id | default: section.id }}"
  style="--mg-fcta-bg: {{ section.settings.background }}; --mg-fcta-text: {{ section.settings.text_color }}; --mg-fcta-pad: {{ section.settings.padding }}px;"
  data-mg-animate-section
>
  {%- if section.settings.image != blank -%}
    <div class="mg-fcta__media">
      {%- render 'responsive-image', image: section.settings.image, sizes: '100vw', class: 'mg-fcta__img', loading: 'lazy' -%}
      {%- if section.settings.overlay_opacity > 0 -%}<span class="mg-fcta__overlay" style="background: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};" aria-hidden="true"></span>{%- endif -%}
    </div>
  {%- endif -%}
  <div class="mg-fcta__inner mg-container">
    <div class="mg-fcta__content" data-mg-animate>
      {%- if section.settings.eyebrow != blank -%}<p class="mg-eyebrow">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="mg-fcta__heading">{{ section.settings.heading | escape }}</h2>{%- endif -%}
      {%- if section.settings.text != blank -%}<div class="mg-fcta__text rte">{{ section.settings.text }}</div>{%- endif -%}
      {%- if section.settings.button_text != blank -%}
        <a class="mg-btn mg-btn--{{ section.settings.button_style }} mg-fcta__btn" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_text | escape }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
.mg-fcta { position: relative; background: var(--mg-fcta-bg, var(--mg-navy)); color: var(--mg-fcta-text, var(--mg-ivory)); overflow: hidden; }
.mg-fcta__media { position: absolute; inset: 0; z-index: 0; }
.mg-fcta__media .mg-picture, .mg-fcta__img { width: 100%; height: 100%; object-fit: cover; }
.mg-fcta__overlay { position: absolute; inset: 0; }
.mg-fcta__inner { position: relative; z-index: 1; padding-block: var(--mg-fcta-pad, 140px); }
.mg-fcta__content { text-align: center; max-width: 720px; margin-inline: auto; }
.mg-fcta__heading { font-size: var(--mg-fs-display); font-weight: 300; line-height: var(--mg-lh-tight); color: inherit; margin-bottom: var(--mg-space-5); }
.mg-fcta__text { font-size: var(--mg-fs-body-lg); color: inherit; opacity: 0.9; margin-bottom: var(--mg-space-7); }
.mg-fcta__btn { margin-top: var(--mg-space-2); }
[data-mg-animate-section] [data-mg-animate] { opacity: 0; transform: translateY(20px); transition: opacity var(--mg-dur-slow) var(--mg-ease), transform var(--mg-dur-slow) var(--mg-ease); }
[data-mg-animate-section].is-revealed [data-mg-animate] { opacity: 1; transform: none; }
@media (prefers-reduced-motion: reduce) { [data-mg-animate-section] [data-mg-animate] { opacity: 1 !important; transform: none !important; } }
{% endstyle %}

{% schema %}
{
  "name": "Footer CTA",
  "tag": "section",
  "class": "mg-fcta-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Begin your Madrishi journey" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Experience luxury crafted for a lifetime.</p>" },
    { "type": "text", "id": "button_text", "label": "Button label", "default": "Explore the collection" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "select", "id": "button_style", "label": "Button style", "options": [ { "value": "primary", "label": "Primary" }, { "value": "secondary", "label": "Secondary" }, { "value": "outline", "label": "Outline" } ], "default": "secondary" },
    { "type": "header", "content": "Background" },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#11182B" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 90, "step": 5, "unit": "%", "label": "Overlay opacity", "default": 50 },
    { "type": "header", "content": "Style" },
    { "type": "color", "id": "background", "label": "Background color", "default": "#1B2A4A" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#F7F4EC" },
    { "type": "range", "id": "padding", "min": 64, "max": 240, "step": 8, "unit": "px", "label": "Vertical padding", "default": 140 },
    { "type": "text", "id": "anchor_id", "label": "Section anchor ID" },
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" }
  ],
  "presets": [ { "name": "Footer CTA" } ]
}
{% endschema %}
