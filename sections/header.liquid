{
  "name": "Header",
  "tag": "header",
  "class": "mg-header-section",
  "settings": [
    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "logo-left", "label": "Logo left, inline navigation" },
        { "value": "logo-center", "label": "Logo centered, navigation below" }
      ],
      "default": "logo-center"
    },
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" },

    { "type": "header", "content": "Behaviour" },
    { "type": "checkbox", "id": "sticky", "label": "Sticky header on scroll", "default": true },
