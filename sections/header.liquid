{%- comment -%}
  ============================================================
  Madrishi Global — Header
  Luxury header with sticky / transparent / shrink-on-scroll,
  desktop nav + dropdowns (mega menu enhanced in Component 3),
  search / account / wishlist / cart triggers, localization.
  Custom element: <mg-header> (+ <mg-localization>)
  Triggers (data attributes) are progressively enhanced by later
  components; today they fall back to real navigation.
  ============================================================
{%- endcomment -%}

{%- liquid
  assign is_transparent = false
  if section.settings.transparent and template.name == 'index'
    assign is_transparent = true
  endif
-%}

<mg-header
  class="mg-header
    {% if section.settings.sticky %}mg-header--sticky{% endif %}
    {% if section.settings.shrink_on_scroll %}mg-header--shrink{% endif %}
    {% if is_transparent %}mg-header--transparent{% endif %}
    mg-header--{{ section.settings.layout }}
    {% if section.settings.border_bottom %}mg-header--bordered{% endif %}
    {{ section.settings.custom_class }}"
  {% if section.settings.sticky %}data-sticky="true"{% endif %}
  {% if section.settings.shrink_on_scroll %}data-shrink="true"{% endif %}
  {% if is_transparent %}data-transparent="true"{% endif %}
  style="
    --mg-header-bg: {{ section.settings.background }};
    --mg-header-text: {{ section.settings.text_color }};
    --mg-header-transparent-text: {{ section.settings.transparent_text_color }};
    --mg-header-height: {{ section.settings.desktop_height }}px;
    --mg-header-height-shrink: {{ section.settings.shrink_height }}px;
    --mg-header-height-mobile: {{ section.settings.mobile_height }}px;
  "
>
  <div class="mg-header__inner mg-container">

    {%- comment -%} Left cluster: mobile menu toggle {%- endcomment -%}
    <div class="mg-header__cluster mg-header__cluster--left">
      <button
        class="mg-header__icon-btn mg-hide-desktop"
        type="button"
        aria-label="{{ 'general.accessibility.menu' | t | default: 'Menu' }}"
        aria-expanded="false"
        aria-controls="mg-mobile-nav"
        data-mg-menu-open
      >
        {%- render 'icon', name: 'menu' -%}
      </button>

      {%- if section.settings.layout == 'logo-left' -%}
        <nav class="mg-header__nav mg-hide-mobile" aria-label="{{ 'general.accessibility.primary_nav' | t | default: 'Primary' }}">
          {%- render 'header-menu', menu: section.settings.menu, blocks: section.blocks -%}
        </nav>
      {%- endif -%}
    </div>

    {%- comment -%} Center: logo {%- endcomment -%}
    <div class="mg-header__logo">
      {%- if request.page_type == 'index' -%}<h1 class="mg-header__logo-heading">{%- else -%}<div class="mg-header__logo-heading">{%- endif -%}
        <a href="{{ routes.root_url }}" class="mg-header__logo-link" aria-label="{{ shop.name }}">
          {%- if settings.logo != blank -%}
            {%- assign logo_alt = settings.logo.alt | default: shop.name -%}
            <img
              class="mg-header__logo-img mg-hide-mobile"
              src="{{ settings.logo | image_url: width: 600 }}"
              srcset="{{ settings.logo | image_url: width: 300 }} 300w, {{ settings.logo | image_url: width: 600 }} 600w"
              sizes="{{ settings.logo_width }}px"
              width="{{ settings.logo.width }}"
              height="{{ settings.logo.height }}"
              alt="{{ logo_alt | escape }}"
              style="width: {{ settings.logo_width }}px;"
              loading="eager"
            >
            {%- if settings.logo_mobile != blank -%}
              <img
                class="mg-header__logo-img mg-hide-desktop"
                src="{{ settings.logo_mobile | image_url: width: 400 }}"
                width="{{ settings.logo_mobile.width }}"
                height="{{ settings.logo_mobile.height }}"
                alt="{{ logo_alt | escape }}"
                style="width: {{ settings.logo_width | times: 0.8 | round }}px;"
                loading="eager"
              >
            {%- else -%}
              <img
                class="mg-header__logo-img mg-hide-desktop"
                src="{{ settings.logo | image_url: width: 400 }}"
                width="{{ settings.logo.width }}"
                height="{{ settings.logo.height }}"
                alt="{{ logo_alt | escape }}"
                style="width: {{ settings.logo_width | times: 0.8 | round }}px;"
                loading="eager"
              >
            {%- endif -%}
          {%- else -%}
            <span class="mg-header__logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      {%- if request.page_type == 'index' -%}</h1>{%- else -%}</div>{%- endif -%}
    </div>

    {%- comment -%} Right cluster: actions {%- endcomment -%}
    <div class="mg-header__cluster mg-header__cluster--right">
      {%- if section.settings.show_localization -%}
        <div class="mg-header__localization mg-hide-mobile">
          {%- render 'localization-form', type: 'country', id: 'header' -%}
        </div>
      {%- endif -%}
      {%- if section.settings.show_language -%}
        <div class="mg-header__localization mg-hide-mobile">
          {%- render 'localization-form', type: 'language', id: 'header' -%}
        </div>
      {%- endif -%}

      {%- if section.settings.show_search -%}
        <a class="mg-header__icon-btn" href="{{ routes.search_url }}" aria-label="{{ 'general.accessibility.search' | t | default: 'Search' }}" data-mg-search-open>
          {%- render 'icon', name: 'search' -%}
        </a>
      {%- endif -%}

      {%- if section.settings.show_account -%}
        <a class="mg-header__icon-btn mg-hide-mobile" href="{{ routes.account_url }}" aria-label="{{ 'general.accessibility.account' | t | default: 'Account' }}">
          {%- render 'icon', name: 'user' -%}
        </a>
      {%- endif -%}

      {%- if section.settings.show_wishlist -%}
        <button class="mg-header__icon-btn mg-header__wishlist" type="button" aria-label="{{ 'general.accessibility.wishlist' | t | default: 'Wishlist' }}" data-mg-wishlist-open>
          {%- render 'icon', name: 'heart' -%}
          <span class="mg-header__count" data-mg-wishlist-count hidden>0</span>
        </button>
      {%- endif -%}

      {%- if section.settings.show_cart -%}
        <a class="mg-header__icon-btn mg-header__cart" href="{{ routes.cart_url }}" aria-label="{{ 'general.accessibility.cart' | t | default: 'Cart' }}" data-mg-cart-open>
          {%- render 'icon', name: 'bag' -%}
          <span class="mg-header__count{% if cart.item_count == 0 %} is-empty{% endif %}" data-mg-cart-count>{{ cart.item_count }}</span>
        </a>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Logo-center layout: nav sits on its own row below {%- endcomment -%}
  {%- if section.settings.layout == 'logo-center' -%}
    <nav class="mg-header__nav mg-header__nav--row mg-hide-mobile" aria-label="{{ 'general.accessibility.primary_nav' | t | default: 'Primary' }}">
      <div class="mg-container">
        {%- render 'header-menu', menu: section.settings.menu, blocks: section.blocks -%}
      </div>
    </nav>
  {%- endif -%}
</mg-header>

{%- comment -%} Sentinel for sticky/transparent scroll detection (no layout cost) {%- endcomment -%}
<div class="mg-header__sentinel" aria-hidden="true"></div>

{%- render 'mobile-nav', menu: section.settings.menu -%}
{%- if section.settings.show_search -%}{%- render 'search-drawer' -%}{%- endif -%}
{%- if section.settings.show_wishlist -%}{%- render 'wishlist-drawer' -%}{%- endif -%}

{% stylesheet %}
.mg-header {
  --_text: var(--mg-header-text, var(--mg-navy));
  position: relative;
  z-index: var(--mg-z-sticky-header);
  background: var(--mg-header-bg, var(--mg-cream));
  color: var(--_text);
  transition: background var(--mg-dur-base) var(--mg-ease), color var(--mg-dur-base) var(--mg-ease), box-shadow var(--mg-dur-base) var(--mg-ease);
}
.mg-header--bordered { border-bottom: var(--mg-border-hairline) solid var(--mg-border-divider); }

.mg-header__inner {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: var(--mg-space-4);
  min-height: var(--mg-header-height, 80px);
  transition: min-height var(--mg-dur-base) var(--mg-ease);
}
.mg-header__cluster { display: flex; align-items: center; gap: var(--mg-space-2); }
.mg-header__cluster--right { justify-content: flex-end; }
.mg-header__logo { display: flex; justify-content: center; }
.mg-header__logo-heading { margin: 0; font-size: inherit; line-height: 0; }
.mg-header__logo-text {
  font-family: var(--mg-font-display);
  font-size: var(--mg-fs-collection-title);
  letter-spacing: var(--mg-track-wide);
  color: var(--_text);
}
.mg-header__logo-img { transition: width var(--mg-dur-base) var(--mg-ease); }

/* Logo-left: logo in left cluster, nav inline */
.mg-header--logo-left .mg-header__inner { grid-template-columns: auto 1fr auto; }
.mg-header--logo-left .mg-header__logo { order: -1; justify-content: flex-start; }
.mg-header--logo-left .mg-header__cluster--left { gap: var(--mg-space-6); }

/* Icon buttons */
.mg-header__icon-btn {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44px; height: 44px;
  color: var(--_text);
  transition: color var(--mg-dur-base) var(--mg-ease), opacity var(--mg-dur-base) var(--mg-ease);
}
.mg-header__icon-btn:hover { color: var(--mg-gold); }
.mg-header__icon-btn svg { width: 22px; height: 22px; }

.mg-header__count {
  position: absolute;
  top: 4px; right: 2px;
  min-width: 18px; height: 18px;
  padding: 0 4px;
  display: inline-flex; align-items: center; justify-content: center;
  background: var(--mg-gold);
  color: var(--mg-navy);
  font-family: var(--mg-font-eyebrow);
  font-size: 10px; font-weight: 600;
  border-radius: var(--mg-radius-pill);
  line-height: 1;
}
.mg-header__count.is-empty { display: none; }

/* Navigation */
.mg-header__menu { display: flex; align-items: center; gap: var(--mg-space-6); }
.mg-header__nav--row { border-top: var(--mg-border-hairline) solid var(--mg-border-divider); }
.mg-header__nav--row .mg-header__menu { justify-content: center; min-height: 52px; }
.mg-header__item { position: relative; }
.mg-header__link {
  display: inline-flex; align-items: center; gap: var(--mg-space-1);
  padding-block: var(--mg-space-3);
  font-family: var(--mg-font-eyebrow);
  font-size: var(--mg-fs-nav);
  font-weight: 500;
  letter-spacing: var(--mg-track-wider);
  text-transform: uppercase;
  color: var(--_text);
}
.mg-header__link:hover,
.mg-header__item:focus-within > .mg-header__link { color: var(--mg-gold); }
.mg-header__link svg { width: 14px; height: 14px; }

/* Dropdown */
.mg-header__dropdown {
  position: absolute;
  top: 100%; left: 0;
  min-width: 220px;
  padding: var(--mg-space-4) 0;
  background: var(--mg-white);
  border: var(--mg-border-hairline) solid var(--mg-border-card);
  box-shadow: var(--mg-shadow-md);
  opacity: 0; visibility: hidden;
  transform: translateY(8px);
  transition: opacity var(--mg-dur-base) var(--mg-ease), transform var(--mg-dur-base) var(--mg-ease), visibility var(--mg-dur-base);
  z-index: var(--mg-z-dropdown);
}
.mg-header__item.has-dropdown:hover > .mg-header__dropdown,
.mg-header__item.has-dropdown:focus-within > .mg-header__dropdown {
  opacity: 1; visibility: visible; transform: translateY(0);
}
.mg-header__dropdown a {
  display: block;
  padding: var(--mg-space-2) var(--mg-space-5);
  font-family: var(--mg-font-body);
  font-size: var(--mg-fs-body-sm);
  letter-spacing: var(--mg-track-normal);
  text-transform: none;
  color: var(--mg-text);
}
.mg-header__dropdown a:hover { color: var(--mg-gold); background: var(--mg-gray-soft); }
.mg-header__subdropdown { padding-left: var(--mg-space-3); }
.mg-header__subdropdown a { color: var(--mg-text-secondary); font-size: var(--mg-fs-caption); }

/* Mega menu — full-width panel anchored to the nav */
.mg-header__nav { position: relative; }
.mg-header__item.has-mega { position: static; }
.mg-mega {
  position: absolute;
  top: 100%; left: 0; right: 0;
  background: var(--mg-white);
  border-top: var(--mg-border-hairline) solid var(--mg-border-divider);
  box-shadow: var(--mg-shadow-md);
  opacity: 0; visibility: hidden;
  transform: translateY(8px);
  transition: opacity var(--mg-dur-base) var(--mg-ease), transform var(--mg-dur-base) var(--mg-ease), visibility var(--mg-dur-base);
  z-index: var(--mg-z-dropdown);
}
.mg-header__item.has-mega:hover > .mg-mega,
.mg-header__item.has-mega:focus-within > .mg-mega { opacity: 1; visibility: visible; transform: translateY(0); }
.mg-mega__inner { padding-block: var(--mg-space-8); }
.mg-mega__columns { display: grid; grid-template-columns: repeat(var(--mega-cols, 4), minmax(0, 1fr)); gap: var(--mg-space-8); align-items: start; }
.mg-mega__col-title { display: block; font-family: var(--mg-font-eyebrow); font-size: var(--mg-fs-caption); font-weight: 600; letter-spacing: var(--mg-track-wider); text-transform: uppercase; color: var(--mg-navy); margin-bottom: var(--mg-space-3); }
.mg-mega__col-title:hover { color: var(--mg-gold); }
.mg-mega__col-list { display: flex; flex-direction: column; gap: var(--mg-space-2); }
.mg-mega__col-link { font-family: var(--mg-font-body); font-size: var(--mg-fs-body-sm); color: var(--mg-text-secondary); text-transform: none; letter-spacing: 0; }
.mg-mega__col-link:hover { color: var(--mg-gold); }
.mg-mega__promo { position: relative; display: block; overflow: hidden; }
.mg-mega__promo-img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--mg-dur-slow) var(--mg-ease); }
.mg-mega__promo:hover .mg-mega__promo-img { transform: scale(1.05); }
.mg-mega__promo-content { position: absolute; left: 0; right: 0; bottom: 0; padding: var(--mg-space-4); color: var(--mg-ivory); background: linear-gradient(to top, rgba(17,24,43,0.6), transparent); }
.mg-mega__promo-heading { display: block; font-family: var(--mg-font-display); font-size: var(--mg-fs-card-heading); }
.mg-mega__promo-cta { display: inline-block; margin-top: var(--mg-space-1); font-family: var(--mg-font-eyebrow); font-size: var(--mg-fs-caption); letter-spacing: var(--mg-track-wide); text-transform: uppercase; border-bottom: 1px solid currentColor; }

/* ---------- Mobile nav drawer ---------- */
.mg-mnav { position: fixed; inset: 0; z-index: var(--mg-z-drawer); }
.mg-mnav[hidden] { display: none; }
.mg-mnav__overlay { position: absolute; inset: 0; background: var(--mg-overlay); opacity: 0; transition: opacity var(--mg-dur-base) var(--mg-ease); }
.mg-mnav.is-open .mg-mnav__overlay { opacity: 1; }
.mg-mnav__panel {
  position: absolute; top: 0; bottom: 0; left: 0;
  width: min(420px, 88vw);
  display: flex; flex-direction: column;
  background: var(--mg-bg-card);
  padding: var(--mg-space-5) var(--mg-space-5) var(--mg-space-8);
  overflow-y: auto;
  transform: translateX(-100%);
  transition: transform var(--mg-dur-base) var(--mg-ease);
  box-shadow: var(--mg-shadow-lg);
}
.mg-mnav.is-open .mg-mnav__panel { transform: translateX(0); }
.mg-mnav__head { display: flex; align-items: center; justify-content: space-between; padding-bottom: var(--mg-space-4); border-bottom: var(--mg-border-hairline) solid var(--mg-border-divider); margin-bottom: var(--mg-space-3); }
.mg-mnav__title { font-family: var(--mg-font-eyebrow); font-size: var(--mg-fs-caption); letter-spacing: var(--mg-track-wider); text-transform: uppercase; color: var(--mg-text-muted); }
.mg-mnav__close { display: inline-flex; width: 40px; height: 40px; align-items: center; justify-content: center; color: var(--mg-navy); }

.mg-mnav__item { border-bottom: var(--mg-border-hairline) solid var(--mg-border-divider); }
.mg-mnav__row { display: flex; align-items: center; justify-content: space-between; }
.mg-mnav__link { display: block; flex: 1; padding: var(--mg-space-4) 0; font-family: var(--mg-font-display); font-size: var(--mg-fs-card-heading); color: var(--mg-navy); }
.mg-mnav__expand { width: 44px; height: 44px; display: inline-flex; align-items: center; justify-content: center; color: var(--mg-navy); }
.mg-mnav__expand .mg-icon--minus { display: none; }
.mg-mnav__expand[aria-expanded="true"] .mg-icon--plus { display: none; }
.mg-mnav__expand[aria-expanded="true"] .mg-icon--minus { display: block; }
.mg-mnav__submenu { padding: 0 0 var(--mg-space-4) var(--mg-space-3); display: flex; flex-direction: column; gap: var(--mg-space-2); }
.mg-mnav__sublink { display: block; padding: var(--mg-space-1) 0; font-size: var(--mg-fs-body); color: var(--mg-text-secondary); }
.mg-mnav__sublink:hover { color: var(--mg-gold); }
.mg-mnav__subsubmenu { padding-left: var(--mg-space-4); margin-top: var(--mg-space-1); }
.mg-mnav__sublink--deep { font-size: var(--mg-fs-body-sm); }

.mg-mnav__cta { margin: var(--mg-space-5) 0; }
.mg-mnav__cta .mg-btn { width: 100%; }
.mg-mnav__utils { display: flex; flex-direction: column; gap: var(--mg-space-1); padding: var(--mg-space-4) 0; border-top: var(--mg-border-hairline) solid var(--mg-border-divider); }
.mg-mnav__util { display: flex; align-items: center; gap: var(--mg-space-3); padding: var(--mg-space-2) 0; font-family: var(--mg-font-eyebrow); font-size: var(--mg-fs-caption); letter-spacing: var(--mg-track-wide); text-transform: uppercase; color: var(--mg-navy); }
.mg-mnav__util:hover { color: var(--mg-gold); }
.mg-mnav__localization { display: flex; flex-direction: column; gap: var(--mg-space-2); padding: var(--mg-space-4) 0; border-top: var(--mg-border-hairline) solid var(--mg-border-divider); }
.mg-mnav__featured { display: block; position: relative; margin: var(--mg-space-5) 0; overflow: hidden; }
.mg-mnav__featured-text { position: absolute; left: var(--mg-space-4); bottom: var(--mg-space-4); color: var(--mg-ivory); font-family: var(--mg-font-display); font-size: var(--mg-fs-card-heading); }
.mg-mnav__foot { margin-top: auto; padding-top: var(--mg-space-5); }
.mg-mnav__contact { margin-top: var(--mg-space-3); font-size: var(--mg-fs-body-sm); color: var(--mg-text-secondary); }

@media (prefers-reduced-motion: reduce) {
  .mg-mnav__panel, .mg-mnav__overlay { transition: none; }
}

/* ---------- Predictive search overlay ---------- */
.mg-search { position: fixed; inset: 0; z-index: var(--mg-z-modal); }
.mg-search[hidden] { display: none; }
.mg-search__overlay { position: absolute; inset: 0; background: var(--mg-overlay); opacity: 0; transition: opacity var(--mg-dur-base) var(--mg-ease); }
.mg-search.is-open .mg-search__overlay { opacity: 1; }
.mg-search__panel {
  position: absolute; top: 0; left: 0; right: 0;
  background: var(--mg-bg-card);
  padding-block: var(--mg-space-5) var(--mg-space-8);
  max-height: 90vh; overflow-y: auto;
  transform: translateY(-100%);
  transition: transform var(--mg-dur-base) var(--mg-ease);
  box-shadow: var(--mg-shadow-lg);
}
.mg-search.is-open .mg-search__panel { transform: translateY(0); }
.mg-search__form { display: flex; align-items: center; gap: var(--mg-space-3); border-bottom: var(--mg-border-thick) solid var(--mg-navy); padding-bottom: var(--mg-space-3); }
.mg-search__icon { display: inline-flex; color: var(--mg-navy); }
.mg-search__input { flex: 1; border: 0; background: transparent; font-family: var(--mg-font-display); font-size: var(--mg-fs-card-heading); color: var(--mg-text); padding: var(--mg-space-2) 0; }
.mg-search__input:focus { outline: none; }
.mg-search__close { display: inline-flex; width: 44px; height: 44px; align-items: center; justify-content: center; color: var(--mg-navy); }
.mg-search__close:hover { color: var(--mg-gold); }
.mg-search__results { margin-top: var(--mg-space-6); }
.mg-search__suggestions { display: flex; flex-wrap: wrap; gap: var(--mg-space-3); }

.mg-predictive__grid { display: grid; grid-template-columns: 2fr 1fr; gap: var(--mg-space-9); }
.mg-predictive__label { font-family: var(--mg-font-eyebrow); font-size: var(--mg-fs-caption); font-weight: 600; letter-spacing: var(--mg-track-wider); text-transform: uppercase; color: var(--mg-text-muted); margin-bottom: var(--mg-space-4); }
.mg-predictive__products { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--mg-space-4); }
.mg-search-item { display: flex; align-items: center; gap: var(--mg-space-3); }
.mg-search-item__media { flex: 0 0 64px; width: 64px; }
.mg-search-item__img { width: 64px; height: 64px; object-fit: cover; }
.mg-search-item__title { display: block; font-size: var(--mg-fs-body-sm); color: var(--mg-text); }
.mg-search-item:hover .mg-search-item__title { color: var(--mg-gold); }
.mg-search-item__price { font-size: var(--mg-fs-body-sm); }
.mg-predictive__list { display: flex; flex-direction: column; gap: var(--mg-space-2); margin-bottom: var(--mg-space-6); }
.mg-predictive__link { font-size: var(--mg-fs-body-sm); color: var(--mg-text-secondary); }
.mg-predictive__link:hover { color: var(--mg-gold); }
.mg-predictive__view-all { margin-top: var(--mg-space-6); }
.mg-predictive__empty { color: var(--mg-text-secondary); }
.mg-search__results.is-loading { opacity: var(--mg-opacity-muted); }

@media (max-width: 767px) {
  .mg-predictive__grid { grid-template-columns: 1fr; gap: var(--mg-space-6); }
  .mg-predictive__products { grid-template-columns: 1fr; }
  .mg-search__input { font-size: var(--mg-fs-body-lg); }
}
@media (prefers-reduced-motion: reduce) { .mg-search__panel, .mg-search__overlay { transition: none; } }

/* Localization */
.mg-localization__wrap { position: relative; }
.mg-localization__current {
  display: inline-flex; align-items: center; gap: var(--mg-space-1);
  padding: var(--mg-space-2);
  font-family: var(--mg-font-eyebrow);
  font-size: var(--mg-fs-caption);
  letter-spacing: var(--mg-track-wide);
  color: var(--_text);
}
.mg-localization__current:hover { color: var(--mg-gold); }
.mg-localization__list {
  position: absolute;
  top: 100%; right: 0;
  min-width: 200px;
  max-height: 320px; overflow-y: auto;
  padding: var(--mg-space-2) 0;
  background: var(--mg-white);
  border: var(--mg-border-hairline) solid var(--mg-border-card);
  box-shadow: var(--mg-shadow-md);
  z-index: var(--mg-z-dropdown);
}
.mg-localization__option {
  display: block; width: 100%;
  padding: var(--mg-space-2) var(--mg-space-4);
  text-align: left;
  font-size: var(--mg-fs-body-sm);
  color: var(--mg-text);
}
.mg-localization__option:hover { background: var(--mg-gray-soft); color: var(--mg-gold); }
.mg-localization__option.is-active { color: var(--mg-gold); }
.mg-localization__currency { color: var(--mg-text-muted); }

/* Sticky */
.mg-header--sticky.is-sticky {
  position: fixed;
  top: 0; left: 0; right: 0;
  box-shadow: var(--mg-shadow-sm);
}
.mg-header__sentinel { height: 0; }
body.mg-has-sticky-spacer { /* spacer applied via JS to prevent jump */ }

/* Shrink */
.mg-header--shrink.is-shrunk .mg-header__inner { min-height: var(--mg-header-height-shrink, 60px); }
.mg-header--shrink.is-shrunk .mg-header__logo-img { width: 80% !important; }

/* Transparent over hero */
.mg-header--transparent {
  position: absolute;
  top: 0; left: 0; right: 0;
  background: transparent;
  color: var(--mg-header-transparent-text, #fff);
}
.mg-header--transparent .mg-header__link,
.mg-header--transparent .mg-header__icon-btn,
.mg-header--transparent .mg-header__logo-text,
.mg-header--transparent .mg-localization__current { color: var(--mg-header-transparent-text, #fff); }
.mg-header--transparent.is-solid {
  position: fixed;
  background: var(--mg-header-bg, var(--mg-cream));
  color: var(--_text);
  box-shadow: var(--mg-shadow-sm);
}
.mg-header--transparent.is-solid .mg-header__link,
.mg-header--transparent.is-solid .mg-header__icon-btn,
.mg-header--transparent.is-solid .mg-header__logo-text,
.mg-header--transparent.is-solid .mg-localization__current { color: var(--_text); }

@media (max-width: 989px) {
  .mg-header__inner { min-height: var(--mg-header-height-mobile, 64px); }
  .mg-header__cluster { gap: 0; }
}
{% endstyle %}

{% javascript %}
class MGHeader extends HTMLElement {
  connectedCallback() {
    this.sticky = this.dataset.sticky === 'true';
    this.shrink = this.dataset.shrink === 'true';
    this.transparent = this.dataset.transparent === 'true';
    this.threshold = 60;
    this.sentinel = this.nextElementSibling;
    this._setHeightVar();

    this._onScroll = this._onScroll.bind(this);
    if (this.sticky || this.shrink || this.transparent) {
      window.addEventListener('scroll', this._onScroll, { passive: true });
      this._onScroll();
    }
    window.addEventListener('resize',
      (window.MG ? MG.utils.debounce(() => this._setHeightVar(), 150) : () => this._setHeightVar())
    );

    // Trigger hooks for later components (drawers). Fallback links still work.
    this._wireTrigger('[data-mg-menu-open]', 'mobile-nav:open');
    this._wireTrigger('[data-mg-search-open]', 'search:open');
    this._wireTrigger('[data-mg-wishlist-open]', 'wishlist:open');
    this._wireTrigger('[data-mg-cart-open]', 'cart:open');

    this._initNav();
  }

  _initNav() {
    this.querySelectorAll('.mg-header__item').forEach((item) => {
      const trigger = item.querySelector('[data-mg-nav-trigger]');
      if (!trigger) return;
      const setState = (open) => trigger.setAttribute('aria-expanded', String(open));
      item.addEventListener('mouseenter', () => setState(true));
      item.addEventListener('mouseleave', () => setState(false));
      item.addEventListener('focusin', () => setState(true));
      item.addEventListener('focusout', (e) => { if (!item.contains(e.relatedTarget)) setState(false); });
      item.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') { setState(false); trigger.focus(); }
      });
    });
  }

  disconnectedCallback() { window.removeEventListener('scroll', this._onScroll); }

  _setHeightVar() {
    document.documentElement.style.setProperty('--mg-header-current-height', this.offsetHeight + 'px');
  }

  _wireTrigger(selector, eventName) {
    const el = this.querySelector(selector);
    if (!el) return;
    el.addEventListener('click', (e) => {
      // Only hijack if a listener exists for the enhanced behaviour
      if (window.MG && MG.events && MG.events.hasListener && MG.events.hasListener(eventName)) {
        e.preventDefault();
      }
      MG.events && MG.events.emit(eventName, { trigger: el });
    });
  }

  _onScroll() {
    const y = window.scrollY;
    if (this.sticky && !this.transparent) {
      const wasSticky = this.classList.contains('is-sticky');
      const makeSticky = y > this.threshold;
      if (makeSticky !== wasSticky) {
        this.classList.toggle('is-sticky', makeSticky);
        document.body.style.paddingTop = makeSticky ? this.offsetHeight + 'px' : '';
      }
    }
    if (this.transparent) {
      this.classList.toggle('is-solid', y > this.threshold);
    }
    if (this.shrink) {
      this.classList.toggle('is-shrunk', y > this.threshold);
    }
  }
}
if (!customElements.get('mg-header')) customElements.define('mg-header', MGHeader);

class MGLocalization extends HTMLElement {
  connectedCallback() {
    this.toggle = this.querySelector('[data-mg-loc-toggle]');
    this.list = this.querySelector('.mg-localization__list');
    if (!this.toggle || !this.list) return;
    this.toggle.addEventListener('click', () => this.toggleOpen());
    document.addEventListener('click', (e) => { if (!this.contains(e.target)) this.close(); });
    this.addEventListener('keydown', (e) => { if (e.key === 'Escape') this.close(); });
  }
  toggleOpen() { this.list.hidden ? this.open() : this.close(); }
  open() { this.list.hidden = false; this.toggle.setAttribute('aria-expanded', 'true'); }
  close() { this.list.hidden = true; this.toggle.setAttribute('aria-expanded', 'false'); }
}
if (!customElements.get('mg-localization')) customElements.define('mg-localization', MGLocalization);

class MGMobileNav extends HTMLElement {
  connectedCallback() {
    this.panel = this.querySelector('.mg-mnav__panel');
    this.trap = window.MG ? new MG.FocusTrap(this.panel) : null;

    if (window.MG && MG.events) MG.events.on('mobile-nav:open', () => this.open());

    this.addEventListener('click', (e) => {
      if (e.target.closest('[data-mg-mnav-close]')) return this.close();
      const toggle = e.target.closest('[data-mg-mnav-toggle]');
      if (toggle) return this._toggle(toggle);
    });
    this.addEventListener('keydown', (e) => { if (e.key === 'Escape') this.close(); });
  }

  open() {
    this.hidden = false;
    requestAnimationFrame(() => this.classList.add('is-open'));
    document.body.style.overflow = 'hidden';
    document.querySelector('[data-mg-menu-open]')?.setAttribute('aria-expanded', 'true');
    if (this.trap) this.trap.activate();
  }
  close() {
    this.classList.remove('is-open');
    document.body.style.overflow = '';
    document.querySelector('[data-mg-menu-open]')?.setAttribute('aria-expanded', 'false');
    if (this.trap) this.trap.deactivate();
    const done = () => { this.hidden = true; this.panel.removeEventListener('transitionend', done); };
    if (window.MG && MG.utils.prefersReducedMotion()) { this.hidden = true; }
    else this.panel.addEventListener('transitionend', done);
  }

  _toggle(btn) {
    const submenu = btn.closest('.mg-mnav__item').querySelector('.mg-mnav__submenu');
    const open = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!open));
    if (submenu) submenu.hidden = open;
  }
}
if (!customElements.get('mg-mobile-nav')) customElements.define('mg-mobile-nav', MGMobileNav);

class MGSearch extends HTMLElement {
  connectedCallback() {
    this.panel = this.querySelector('.mg-search__panel');
    this.input = this.querySelector('[data-mg-search-input]');
    this.results = this.querySelector('[data-mg-search-results]');
    this.defaultState = this.querySelector('[data-mg-search-default]');
    this.suggestUrl = this.dataset.suggestUrl;
    this.sectionId = this.dataset.section;
    this.trap = window.MG ? new MG.FocusTrap(this.panel) : null;

    if (window.MG && MG.events) MG.events.on('search:open', () => this.open());

    this.addEventListener('click', (e) => { if (e.target.closest('[data-mg-search-close]')) this.close(); });
    this.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') this.close();
      if (e.key === 'ArrowDown' || e.key === 'ArrowUp') this._arrow(e);
    });

    this._search = (window.MG ? MG.utils.debounce : (f) => f)(() => this._fetch(), 250);
    if (this.input) this.input.addEventListener('input', () => this._search());
  }

  open() {
    this.hidden = false;
    requestAnimationFrame(() => this.classList.add('is-open'));
    document.body.style.overflow = 'hidden';
    document.querySelector('[data-mg-search-open]')?.setAttribute('aria-expanded', 'true');
    if (this.trap) this.trap.activate();
    setTimeout(() => this.input && this.input.focus(), 80);
  }
  close() {
    this.classList.remove('is-open');
    document.body.style.overflow = '';
    document.querySelector('[data-mg-search-open]')?.setAttribute('aria-expanded', 'false');
    if (this.trap) this.trap.deactivate();
    const done = () => { this.hidden = true; this.panel.removeEventListener('transitionend', done); };
    if (window.MG && MG.utils.prefersReducedMotion()) this.hidden = true;
    else this.panel.addEventListener('transitionend', done);
  }

  async _fetch() {
    const q = this.input.value.trim();
    if (q.length < 2) { this._restoreDefault(); return; }
    if (this._controller) this._controller.abort();
    this._controller = new AbortController();
    this.results.classList.add('is-loading');
    const url = `${this.suggestUrl}?q=${encodeURIComponent(q)}&section_id=${this.sectionId}` +
      `&resources[type]=product,collection,article,query&resources[limit]=6`;
    try {
      const res = await fetch(url, { signal: this._controller.signal });
      const text = await res.text();
      const doc = new DOMParser().parseFromString(text, 'text/html');
      const block = doc.querySelector('[data-mg-predictive]');
      if (this.defaultState) this.defaultState.hidden = true;
      this.results.querySelector('[data-mg-predictive]')?.remove();
      if (block) this.results.appendChild(document.importNode(block, true));
    } catch (e) {
      if (e.name !== 'AbortError') { /* leave previous results */ }
    } finally {
      this.results.classList.remove('is-loading');
    }
  }

  _restoreDefault() {
    this.results.querySelector('[data-mg-predictive]')?.remove();
    if (this.defaultState) this.defaultState.hidden = false;
  }

  _arrow(e) {
    const links = Array.from(this.results.querySelectorAll('a'));
    if (!links.length) return;
    e.preventDefault();
    const idx = links.indexOf(document.activeElement);
    let next = e.key === 'ArrowDown' ? idx + 1 : idx - 1;
    if (next < 0) next = links.length - 1;
    if (next >= links.length) next = 0;
    links[next].focus();
  }
}
if (!customElements.get('mg-search')) customElements.define('mg-search', MGSearch);
{% endjavascript %}

