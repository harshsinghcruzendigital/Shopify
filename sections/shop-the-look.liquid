{%- comment -%}
  ============================================================
  Madrishi Global — Homepage Section 10: Shop the Look
  Lifestyle image with positioned product hotspots. Tapping a dot
  reveals a mini product card (image, title, price, view + quick-add).
  Quick-add posts to /cart/add and opens the cart drawer (cart.js).
  Custom element: <mg-shop-look>
  ============================================================
{%- endcomment -%}

<section
  class="mg-stl {{ section.settings.custom_class }}"
  id="{{ section.settings.anchor_id | default: section.id }}"
  style="
    --mg-stl-bg: {{ section.settings.background }};
    --mg-stl-text: {{ section.settings.text_color }};
    --mg-stl-dot: {{ section.settings.dot_color }};
    --mg-stl-pad-top: {{ section.settings.padding_top }}px;
    --mg-stl-pad-bottom: {{ section.settings.padding_bottom }}px;
  "
  data-mg-animate-section
>
  <div class="mg-stl__inner mg-container">
    {%- if section.settings.heading != blank or section.settings.eyebrow != blank -%}
      <div class="mg-section-header mg-section-header--center">
        {%- if section.settings.eyebrow != blank -%}<p class="mg-section-header__eyebrow mg-eyebrow" data-mg-animate>{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="mg-section-header__title" data-mg-animate>{{ section.settings.heading | escape }}</h2>{%- endif -%}
      </div>
    {%- endif -%}

    <mg-shop-look class="mg-stl__canvas" data-mg-animate>
      <div class="mg-stl__image">
        {%- if section.settings.image != blank -%}
          {%- render 'responsive-image', image: section.settings.image, mobile: section.settings.image_mobile, sizes: '(min-width:1280px) 1200px, 100vw', class: 'mg-stl__img', aspect_ratio: section.settings.image_ratio -%}
        {%- else -%}
          <div class="mg-image-placeholder" style="aspect-ratio: {{ section.settings.image_ratio }};">{{ 'lifestyle-2' | placeholder_svg_tag }}</div>
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        {%- assign product = block.settings.product -%}
        <div class="mg-stl__hotspot" style="left: {{ block.settings.x }}%; top: {{ block.settings.y }}%;" {{ block.shopify_attributes }}>
          <button class="mg-stl__dot" type="button" aria-expanded="false" data-mg-hotspot aria-label="{% if product != blank %}{{ product.title | escape }}{% else %}Product{% endif %}">
            <span class="mg-stl__dot-inner" aria-hidden="true">{%- render 'icon', name: 'plus', size: 14 -%}</span>
          </button>
          {%- if product != blank -%}
            <div class="mg-stl__card" role="group" aria-label="{{ product.title | escape }}">
              <a class="mg-stl__card-media" href="{{ product.url }}" tabindex="-1" aria-hidden="true">
                {%- if product.featured_media -%}
                  {%- render 'responsive-image', image: product.featured_media.preview_image, sizes: '96px', class: 'mg-stl__card-img', widths: '96,192', aspect_ratio: '1/1' -%}
                {%- endif -%}
              </a>
              <div class="mg-stl__card-info">
                <a class="mg-stl__card-title" href="{{ product.url }}">{{ product.title | escape }}</a>
                {%- render 'price', product: product, class: 'mg-stl__card-price', show_compare: false -%}
                <div class="mg-stl__card-actions">
                  {%- if product.available -%}
                    <form action="{{ routes.cart_url }}/add" method="post" data-mg-product-form class="mg-stl__add-form">
                      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                      <button type="submit" class="mg-btn mg-btn--primary mg-stl__add">{{ 'products.card.add' | t | default: 'Add' }}</button>
                    </form>
                  {%- else -%}
                    <span class="mg-stl__soldout">{{ 'products.card.sold_out' | t | default: 'Sold out' }}</span>
                  {%- endif -%}
                  <a class="mg-btn mg-btn--text mg-stl__view" href="{{ product.url }}">{{ 'products.card.view' | t | default: 'View' }}</a>
                </div>
              </div>
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </mg-shop-look>
  </div>
</section>

{% stylesheet %}
.mg-stl { background: var(--mg-stl-bg, var(--mg-bg-page)); color: var(--mg-stl-text, var(--mg-text)); padding-block: var(--mg-stl-pad-top, var(--mg-section-spacing)) var(--mg-stl-pad-bottom, var(--mg-section-spacing)); }
.mg-stl .mg-section-header__title { color: inherit; }
.mg-stl__canvas { position: relative; display: block; margin-top: var(--mg-space-8); }
.mg-stl__img { width: 100%; height: auto; display: block; }

.mg-stl__hotspot { position: absolute; transform: translate(-50%, -50%); z-index: 1; }
.mg-stl__hotspot:focus-within, .mg-stl__hotspot.is-active { z-index: 3; }
.mg-stl__dot { width: 34px; height: 34px; display: inline-flex; align-items: center; justify-content: center; border-radius: 50%; background: rgba(255,255,255,0.9); color: var(--mg-navy); box-shadow: 0 0 0 0 rgba(255,255,255,0.6); animation: mg-stl-pulse 2.4s var(--mg-ease) infinite; transition: transform var(--mg-dur-base) var(--mg-ease); }
.mg-stl__dot:hover, .mg-stl__hotspot.is-active .mg-stl__dot { transform: scale(1.1); }
.mg-stl__dot-inner { display: inline-flex; transition: transform var(--mg-dur-base) var(--mg-ease); }
.mg-stl__hotspot.is-active .mg-stl__dot-inner { transform: rotate(45deg); }
@keyframes mg-stl-pulse { 0% { box-shadow: 0 0 0 0 rgba(255,255,255,0.5); } 70% { box-shadow: 0 0 0 12px rgba(255,255,255,0); } 100% { box-shadow: 0 0 0 0 rgba(255,255,255,0); } }

.mg-stl__card { position: absolute; bottom: calc(100% + 14px); left: 50%; transform: translateX(-50%) translateY(8px); width: 280px; max-width: 80vw; display: flex; gap: var(--mg-space-3); padding: var(--mg-space-3); background: var(--mg-white); color: var(--mg-text); box-shadow: var(--mg-shadow-md); opacity: 0; visibility: hidden; transition: opacity var(--mg-dur-base) var(--mg-ease), transform var(--mg-dur-base) var(--mg-ease), visibility var(--mg-dur-base); }
.mg-stl__hotspot.is-active .mg-stl__card, .mg-stl__hotspot:focus-within .mg-stl__card { opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0); }
.mg-stl__card-media { flex: 0 0 72px; }
.mg-stl__card-img { width: 72px; height: 72px; object-fit: cover; }
.mg-stl__card-info { display: flex; flex-direction: column; gap: var(--mg-space-1); min-width: 0; }
.mg-stl__card-title { font-family: var(--mg-font-display); font-size: var(--mg-fs-product-title); color: var(--mg-text); }
.mg-stl__card-title:hover { color: var(--mg-gold); }
.mg-stl__card-actions { display: flex; align-items: center; gap: var(--mg-space-3); margin-top: var(--mg-space-1); }
.mg-stl__add { --_btn-h: 36px; min-height: 36px; padding-inline: var(--mg-space-4); font-size: var(--mg-fs-badge); }
.mg-stl__soldout { font-size: var(--mg-fs-caption); color: var(--mg-text-muted); }

[data-mg-animate-section] [data-mg-animate] { opacity: 0; transform: translateY(20px); transition: opacity var(--mg-dur-slow) var(--mg-ease), transform var(--mg-dur-slow) var(--mg-ease); }
[data-mg-animate-section].is-revealed [data-mg-animate] { opacity: 1; transform: none; }
@media (prefers-reduced-motion: reduce) { .mg-stl__dot { animation: none; } [data-mg-animate-section] [data-mg-animate] { opacity: 1 !important; transform: none !important; } }
{% endstyle %}

{% javascript %}
class MGShopLook extends HTMLElement {
  connectedCallback() {
    this.addEventListener('click', (e) => {
      const dot = e.target.closest('[data-mg-hotspot]');
      if (!dot) return;
      const spot = dot.closest('.mg-stl__hotspot');
      const open = spot.classList.contains('is-active');
      this._closeAll();
      if (!open) { spot.classList.add('is-active'); dot.setAttribute('aria-expanded', 'true'); }
    });
    document.addEventListener('click', (e) => { if (!this.contains(e.target)) this._closeAll(); });
    this.addEventListener('keydown', (e) => { if (e.key === 'Escape') this._closeAll(); });
  }
  _closeAll() {
    this.querySelectorAll('.mg-stl__hotspot.is-active').forEach((s) => {
      s.classList.remove('is-active');
      s.querySelector('[data-mg-hotspot]')?.setAttribute('aria-expanded', 'false');
    });
  }
}
if (!customElements.get('mg-shop-look')) customElements.define('mg-shop-look', MGShopLook);
{% endjavascript %}

{% schema %}
{
  "name": "Shop the look",
  "tag": "section",
  "class": "mg-stl-section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop the Look" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Styled by Madrishi" },
    { "type": "image_picker", "id": "image", "label": "Lifestyle image" },
    { "type": "image_picker", "id": "image_mobile", "label": "Mobile image" },
    { "type": "select", "id": "image_ratio", "label": "Image ratio", "options": [ { "value": "16/9", "label": "Landscape (16:9)" }, { "value": "4/3", "label": "4:3" }, { "value": "3/2", "label": "3:2" }, { "value": "1/1", "label": "Square" } ], "default": "16/9" },

    { "type": "header", "content": "Style" },
    { "type": "color", "id": "background", "label": "Background", "default": "#FBF8F2" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#1C1C1C" },
    { "type": "color", "id": "dot_color", "label": "Hotspot color", "default": "#FFFFFF" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 200, "step": 8, "unit": "px", "label": "Padding top", "default": 120 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 200, "step": 8, "unit": "px", "label": "Padding bottom", "default": 120 },

    { "type": "header", "content": "Advanced" },
    { "type": "text", "id": "anchor_id", "label": "Section anchor ID" },
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Product hotspot",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "range", "id": "x", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "Horizontal position", "default": 50 },
        { "type": "range", "id": "y", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "Vertical position", "default": 50 }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    { "name": "Shop the look", "blocks": [ { "type": "hotspot", "settings": { "x": 35, "y": 45 } }, { "type": "hotspot", "settings": { "x": 65, "y": 60 } } ] }
  ]
}
{% endschema %}
